<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, viewport-fit=cover" />
  <title>NorthStar Ledger</title>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    /* ═══════════════════════════════════════════
       BRAND TOKENS — matches login page exactly
    ═══════════════════════════════════════════ */
    :root {
      --gold:          #f5c842;
      --gold-lt:       #ffe78a;
      --gold-dk:       #c99a00;
      --gold-glow:     rgba(245,200,66,0.35);
      --purple-deep:   #1a0d2e;
      --purple-mid:    #2d1654;
      --purple-lite:   #3d2070;
      --purple-card:   #231340;
      --ring-pink:     #c96dd8;
      --bar-blue:      #4a90d9;
      --bar-teal:      #2bc4c4;
      --bar-pink:      #e8478c;
      --bar-orange:    #f0a030;
      --ok:            #22c97a;
      --ok-bg:         rgba(34,201,122,0.12);
      --ok-border:     rgba(34,201,122,0.3);
      --warn:          #f0a030;
      --warn-bg:       rgba(240,160,48,0.12);
      --bad:           #ff5b72;
      --bad-bg:        rgba(255,91,114,0.12);
      --bad-border:    rgba(255,91,114,0.3);
      --ink:           #1a0d2e;
      --muted:         #a08cc0;
      --line:          rgba(255,255,255,0.08);
      --line-light:    rgba(200,170,255,0.15);
      --card-bg:       #ffffff;
      --card-bg-tint:  #f8f5ff;
      --input-bg:      #f4f0fc;
      --input-bd:      #ddd0f5;
      --sidebar-bg:    #1e0f38;
      --topbar-bg:     #160a28;
      --panel-bg:      #f8f5ff;
      --tint-soft:     #ede5f8;
      --tint-mid:      #ddd0f5;
      --pink:          #c96dd8;
      --pink-dark:     #3d2070;
      --radius:        14px;
      --radius-sm:     10px;
      --radius-xs:     7px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #100820;
      color: var(--ink);
      -webkit-text-size-adjust: 100%;
      text-size-adjust: 100%;
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* Subtle starfield on body */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        radial-gradient(1px 1px at 15% 20%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 42% 8%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 68% 15%, rgba(255,255,255,0.35) 0%, transparent 100%),
        radial-gradient(1px 1px at 88% 30%, rgba(255,255,255,0.25) 0%, transparent 100%),
        radial-gradient(1px 1px at 5% 60%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 92% 70%, rgba(255,255,255,0.2) 0%, transparent 100%),
        radial-gradient(2px 2px at 30% 85%, rgba(245,200,66,0.2) 0%, transparent 100%),
        radial-gradient(2px 2px at 75% 90%, rgba(201,109,216,0.2) 0%, transparent 100%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── LAYOUT ── */
    .wrap { max-width: 1600px; margin: 0 auto; padding: 0 16px 32px; position: relative; z-index: 1; }
    .layout { display: grid; grid-template-columns: 230px 1fr; gap: 16px; align-items: start; padding-top: 16px; }
    .layout > * { min-width: 0; }

    /* ── TOPBAR ── */
    #top {
      position: static;
      background: var(--topbar-bg);
      border: 1px solid var(--line-light);
      border-radius: var(--radius);
      padding: 14px 18px;
      margin-bottom: 0;
      box-shadow: 0 4px 24px rgba(0,0,0,0.4), 0 0 0 1px rgba(245,200,66,0.08);
    }

    /* ── SIDEBAR ── */
    .sidebar {
      position: sticky;
      top: 10px;
    }
    .sidebar-inner {
      background: var(--sidebar-bg);
      border: 1px solid var(--line-light);
      border-radius: var(--radius);
      padding: 18px 14px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.3);
    }

    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 20px;
      padding-bottom: 16px;
      border-bottom: 1px solid var(--line-light);
    }
    .sidebar-brand img { width: 36px; height: 36px; object-fit: contain; }
    .sidebar-brand-name {
      font-family: 'Cinzel', serif;
      font-size: 13px;
      font-weight: 700;
      color: #fff;
      line-height: 1.2;
    }
    .sidebar-brand-name span { color: var(--gold); }

    .sidebar-section-label {
      font-size: 9.5px;
      font-weight: 600;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: var(--muted);
      margin: 0 4px 8px;
    }

    .nav-links { display: grid; gap: 4px; margin-bottom: 18px; }

    .pill {
      display: block;
      padding: 9px 14px;
      border-radius: var(--radius-sm);
      background: transparent;
      border: 1px solid transparent;
      color: #c0a8e0;
      font-size: 13.5px;
      font-weight: 500;
      text-decoration: none;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
      cursor: pointer;
    }
    .pill:hover { background: rgba(255,255,255,0.06); color: #fff; }
    .pill.active {
      background: linear-gradient(135deg, rgba(245,200,66,0.18), rgba(201,109,216,0.15));
      border-color: rgba(245,200,66,0.3);
      color: var(--gold) !important;
      font-weight: 700;
    }

    /* ── CALCULATOR in sidebar ── */
    .calc-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--line-light);
      border-radius: var(--radius-sm);
      padding: 14px;
      margin-top: 8px;
    }
    .calc-title {
      font-family: 'Cinzel', serif;
      font-size: 12px;
      font-weight: 700;
      color: var(--gold);
      letter-spacing: 0.5px;
      margin-bottom: 10px;
    }
    #rcDisplay {
      width: 100%;
      background: rgba(0,0,0,0.35);
      border: 1px solid var(--line-light);
      border-radius: var(--radius-xs);
      color: #fff;
      font-size: 15px;
      font-weight: 600;
      text-align: right;
      padding: 8px 10px;
      margin-bottom: 8px;
      font-family: 'DM Sans', monospace;
    }
    .calc-grid-btns {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 5px;
    }
    .calc-btn {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 7px;
      color: #e0d0ff;
      font-size: 13px;
      font-weight: 600;
      padding: 7px 4px;
      cursor: pointer;
      min-height: 32px;
      transition: background 0.12s, color 0.12s;
      font-family: 'DM Sans', sans-serif;
      white-space: nowrap;
    }
    .calc-btn:hover { background: rgba(245,200,66,0.18); color: var(--gold); border-color: rgba(245,200,66,0.3); }
    .calc-btn.eq {
      background: linear-gradient(135deg, var(--gold), var(--bar-orange));
      color: var(--purple-deep);
      border-color: transparent;
    }
    .calc-btn.eq:hover { filter: brightness(1.08); }
    .calc-btn.op { color: var(--gold); }

    /* ── MAIN CARDS ── */
    .card {
      background: var(--card-bg);
      border: 1px solid rgba(200,170,255,0.2);
      border-radius: var(--radius);
      padding: 18px;
      margin-bottom: 16px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.08);
      animation: fadeUp 0.4s ease both;
    }
    .card.dark-card {
      background: var(--purple-card);
      border-color: var(--line-light);
      color: #e8deff;
      box-shadow: 0 4px 24px rgba(0,0,0,0.3);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── TOPBAR INTERNALS ── */
    .topbar-row1, .topbar-row2 {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }
    .topbar-row1 { margin-bottom: 10px; }

    .app-brand {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .app-brand img {
      width: 42px; height: 42px;
      object-fit: contain;
      filter: drop-shadow(0 2px 8px rgba(245,200,66,0.4));
    }
    .app-brand-text { }
    .app-brand-name {
      font-family: 'Cinzel', serif;
      font-size: 18px;
      font-weight: 900;
      color: #fff;
      letter-spacing: 0.3px;
      line-height: 1.1;
    }
    .app-brand-name span { color: var(--gold); }
    .app-brand-sub {
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }

    .topbar-controls { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

    .top-pill-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 14px;
      border-radius: 999px;
      border: 1px solid var(--line-light);
      background: rgba(255,255,255,0.06);
      color: #d8c8f0;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      font-family: 'DM Sans', sans-serif;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .top-pill-btn:hover { background: rgba(245,200,66,0.12); border-color: rgba(245,200,66,0.3); color: var(--gold); }

    .month-nav { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
    .month-label {
      font-family: 'Cinzel', serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--gold);
      padding: 0 8px;
    }

    .household-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(245,200,66,0.1);
      border: 1px solid rgba(245,200,66,0.25);
      color: var(--gold);
      padding: 5px 14px;
      border-radius: 999px;
      font-size: 12.5px;
      font-weight: 700;
    }

    /* ── NOTES section ── */
    .notes-section {
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px dashed rgba(200,170,255,0.2);
    }
    .notes-label {
      font-family: 'Cinzel', serif;
      font-size: 12px;
      font-weight: 700;
      color: var(--gold);
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }
    textarea {
      width: 100%;
      background: rgba(255,255,255,0.06);
      border: 1px solid var(--line-light);
      border-radius: var(--radius-sm);
      color: #e0d0ff;
      font-size: 13.5px;
      font-family: 'DM Sans', sans-serif;
      padding: 10px 12px;
      resize: vertical;
      outline: none;
      transition: border-color 0.2s;
    }
    textarea:focus { border-color: rgba(245,200,66,0.4); }
    textarea::placeholder { color: rgba(160,140,192,0.6); }

    /* ── SECTION HEADINGS ── */
    h2 { font-family: 'Cinzel', serif; font-size: 20px; font-weight: 900; color: var(--purple-deep); margin: 0 0 14px; }
    h3 { font-family: 'Cinzel', serif; font-size: 15px; font-weight: 700; color: var(--purple-deep); margin: 0 0 12px; }
    .dark-card h2, .dark-card h3 { color: var(--gold); }
    #top h2, #top h3 { color: #fff; margin: 0; }

    .section-title {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'Cinzel', serif;
      font-size: 13px;
      font-weight: 700;
      color: var(--purple-lite);
      background: var(--tint-soft);
      border: 1px solid var(--tint-mid);
      border-radius: 999px;
      padding: 4px 14px;
      margin-bottom: 12px;
    }

    /* ── OVERVIEW STAT CARDS ── */
    .overview-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      margin-bottom: 16px;
    }
    .stat-card {
      border-radius: var(--radius-sm);
      padding: 16px;
      border: 1px solid;
      position: relative;
      overflow: hidden;
    }
    .stat-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
    }
    .stat-card.balance { background: linear-gradient(135deg, #f0fff8, #e6fff4); border-color: rgba(34,201,122,0.25); }
    .stat-card.balance::before { background: var(--ok); }
    .stat-card.income  { background: linear-gradient(135deg, #fff8e6, #fff3d0); border-color: rgba(245,200,66,0.3); }
    .stat-card.income::before { background: var(--gold); }
    .stat-card.bills   { background: linear-gradient(135deg, #f8f0ff, #f0e6ff); border-color: rgba(201,109,216,0.25); }
    .stat-card.bills::before { background: var(--ring-pink); }

    .stat-card-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #7a6a9a;
      margin-bottom: 6px;
    }
    .overview-value {
      font-family: 'Cinzel', serif;
      font-size: 26px;
      font-weight: 900;
      color: var(--purple-deep);
      letter-spacing: -0.5px;
    }

    /* ── BADGES ── */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border-radius: 999px;
      font-size: 11.5px;
      font-weight: 700;
      line-height: 1.3;
    }
    .badge-due     { background: #ffe3e8; color: #b00030; }
    .badge-paid    { background: #dcfce7; color: #166534; }
    .badge-bill    { background: #fff3e0; color: #7a3e00; }
    .badge-promo   { background: #ffe3e8; color: #b00030; }
    .badge-trip    { background: #ede3ff; color: #5a2d91; }
    .badge-paycheck{ background: #dcfce7; color: #166534; }
    .badge-status-ok   { background: var(--ok-bg); border: 1px solid var(--ok-border); color: #0a7a4a; }
    .badge-status-bad  { background: var(--bad-bg); border: 1px solid var(--bad-border); color: #9a0020; }

    /* ── FORMS & INPUTS ── */
    input, select {
      padding: 9px 12px;
      border-radius: var(--radius-sm);
      border: 1.5px solid var(--input-bd);
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      background: var(--input-bg);
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    input:focus, select:focus {
      border-color: var(--purple-lite);
      box-shadow: 0 0 0 3px rgba(61,32,112,0.1);
    }
    input::placeholder { color: #b0a0cc; }
    input[type="date"], input[type="month"] {
      height: 42px; min-height: 42px; min-width: 160px;
      -webkit-appearance: none; appearance: none;
    }
    input[type="checkbox"] { width: 16px; height: 16px; cursor: pointer; }

    button {
      padding: 9px 18px;
      border-radius: var(--radius-sm);
      border: none;
      background: linear-gradient(135deg, var(--purple-lite), var(--purple-mid));
      color: #fff;
      font-size: 14px;
      font-weight: 700;
      font-family: 'DM Sans', sans-serif;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      min-height: 38px;
      white-space: nowrap;
      transition: filter 0.15s, transform 0.12s;
    }
    button:hover { filter: brightness(1.12); transform: translateY(-1px); }
    button:active { transform: translateY(0); }

    .btn-gold {
      background: linear-gradient(135deg, var(--gold), var(--bar-orange));
      color: var(--purple-deep);
      box-shadow: 0 4px 16px rgba(245,200,66,0.3);
    }
    .btn-muted { background: #9a8cba; }
    .btn-danger { background: linear-gradient(135deg, #e03050, #b00020); }
    .btn-sm { padding: 4px 10px; min-height: 28px; font-size: 12px; }

    form { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
    .stack-form { display: block !important; }
    .field-row {
      display: grid;
      grid-template-columns: 130px 1fr;
      gap: 8px;
      align-items: center;
      margin-bottom: 10px;
    }
    .field-row label { font-size: 13px; font-weight: 600; color: #4a3a6a; }
    .stack-form input, .stack-form select { width: 100%; }
    .actions { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; }

    /* ── TABLE ── */
    table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    th, td { border: 1px solid #ede5f8; padding: 8px 10px; text-align: center; }
    th { background: var(--tint-soft); font-size: 12px; font-weight: 700; letter-spacing: 0.3px; color: var(--purple-lite); text-transform: uppercase; }
    tr:nth-child(even):not([style*="background"]) { background: #faf7ff; }
    tr:nth-child(odd):not([style*="background"]) { background: #fff; }

    .planner-table, .adaptive-table { width: 100%; table-layout: fixed; }
    .planner-table th, .planner-table td,
    .adaptive-table th, .adaptive-table td {
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      font-size: clamp(11px, 1vw, 13.5px);
    }
    .planner-table th, .adaptive-table th { white-space: normal; overflow: visible; }
    .planner-table td:nth-child(2), .planner-table th:nth-child(2) {
      white-space: normal; overflow: visible; text-overflow: clip;
      overflow-wrap: anywhere; word-break: break-word; min-width: 160px;
    }
    .planner-table td button, .adaptive-table td button { width: 100%; max-width: 100%; font-size: clamp(11px,.9vw,13px); }
    .planner-table tr:nth-child(even):not([style]) { background: #faf7ff; }
    .planner-table tr:nth-child(odd):not([style]) { background: #fff; }

    /* ── PROGRESS BARS ── */
    .progress-wrap {
      height: 10px;
      background: var(--tint-soft);
      border-radius: 999px;
      overflow: hidden;
      margin: 6px 0 4px;
    }
    .progress-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--purple-lite), var(--ring-pink));
      border-radius: 999px;
      transition: width 0.5s ease;
    }
    .progress-label {
      font-size: 12px;
      color: var(--purple-lite);
      font-weight: 600;
    }

    /* ── TRIP CARD ── */
    .trip-card {
      border: 1px solid var(--tint-mid);
      border-radius: var(--radius-sm);
      padding: 14px;
      background: #fff;
      margin-bottom: 10px;
      box-shadow: 0 1px 6px rgba(61,32,112,0.06);
    }
    .trip-card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
      flex-wrap: wrap;
      gap: 6px;
    }
    .trip-card-name { font-weight: 700; font-size: 15px; color: var(--purple-deep); }
    .trip-card-due { font-size: 12px; color: var(--ring-pink); font-weight: 600; }
    .trip-stats-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 10px;
      font-size: 13px;
    }
    .trip-stat-label { color: var(--purple-lite); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 2px; }
    .trip-stat-val { font-weight: 700; color: var(--purple-deep); }

    /* ── CALENDAR ── */
    .calendar-grid { table-layout: fixed; }
    .calendar-cell { vertical-align: top; height: 90px; width: 14.285%; overflow: hidden; }
    .calendar-events { display: flex; flex-direction: column; gap: 1px; max-height: 62px; overflow: auto; }
    .calendar-events .badge { display: block; max-width: 100%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 10px; padding: 2px 6px; border-radius: 4px; }
    .cal-event-btn { border: none; padding: 0; background: transparent; text-align: left; cursor: pointer; width: 100%; }
    .calendar-more-btn { border: 1px solid var(--tint-mid); background: #fff; color: var(--purple-lite); padding: 1px 6px; margin-top: 1px; border-radius: 6px; font-size: 10px; font-weight: 700; cursor: pointer; }
    .calendar-day-num {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 22px; height: 22px; border-radius: 999px; padding: 0 4px;
      font-size: 12px; font-weight: 600; color: var(--purple-deep);
    }
    .calendar-day-num.today {
      background: linear-gradient(135deg, var(--purple-lite), var(--ring-pink));
      color: #fff; font-weight: 800;
    }

    /* ── STATUS colors ── */
    .good  { color: #137a3a; font-weight: 600; }
    .warn  { color: #a65b00; font-weight: 600; }
    .bad   { color: #b00020; font-weight: 700; }

    /* ── CALC BOX (promotions page) ── */
    .calc-box {
      border: 1px solid var(--tint-mid);
      border-radius: var(--radius-sm);
      padding: 16px;
      background: #fff;
    }
    .calc-result { margin-top: 10px; font-size: 15px; line-height: 1.5; text-align: center; font-weight: 600; color: var(--purple-deep); }

    /* ── MODAL OVERLAYS ── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(16,8,32,0.75);
      z-index: 9999;
      backdrop-filter: blur(2px);
    }
    .modal-box {
      max-width: 440px;
      margin: 8vh auto;
      background: #fff;
      border: 1px solid var(--tint-mid);
      border-radius: var(--radius);
      padding: 22px;
      box-shadow: 0 24px 64px rgba(0,0,0,0.3), 0 0 0 1px rgba(245,200,66,0.1);
    }
    .modal-box h3 {
      margin-top: 0;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--tint-soft);
      margin-bottom: 16px;
    }
    .modal-wide { max-width: 780px; max-height: 84vh; overflow: auto; }

    /* Settings modal */
    .settings-sidebar {
      display: grid;
      gap: 6px;
    }
    .settings-tab-btn {
      display: block;
      width: 100%;
      text-align: left;
      padding: 9px 14px;
      border-radius: var(--radius-sm);
      border: 1px solid transparent;
      background: var(--tint-soft);
      color: var(--purple-lite);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: background 0.15s, color 0.15s;
    }
    .settings-tab-btn:hover { background: var(--tint-mid); color: var(--purple-deep); transform: none; filter: none; }

    /* ── PLAN PILL ── */
    .plan-pill {
      display: inline-flex; align-items: center;
      font-size: 10px; background: #fff3b0; color: #7a5a00;
      padding: 1px 6px; border-radius: 999px; font-weight: 700;
      white-space: nowrap;
    }

    /* ── PROMO FORM ── */
    .promo-inline { display: flex; align-items: center; gap: 8px; }
    .promo-inline label { font-weight: 600; white-space: nowrap; min-width: 115px; text-align: right; font-size: 13px; }
    .promo-inline input { width: 100%; }

    /* ── DATE HINT ── */
    .date-hint-wrap { position: relative; display: inline-flex; align-items: center; min-width: 160px; }
    .date-hint-wrap input[type="date"], .date-hint-wrap input[type="month"] { position: relative; z-index: 1; }
    .date-hint-wrap .date-hint { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #b0a0cc; font-size: 14px; pointer-events: none; z-index: 2; white-space: nowrap; }
    .date-hint-wrap.has-value .date-hint { display: none; }

    /* ── TOUR MODAL ── */
    #tourModal .modal-box { max-width: 600px; }

    /* ── LIST STYLES ── */
    ul { margin: 8px 0 0 18px; padding: 0; }
    li { margin-bottom: 6px; font-size: 13.5px; }
    a { color: var(--purple-lite); font-weight: 700; text-decoration: none; }
    a:hover { color: var(--ring-pink); }

    /* ── ROW GRID ── */
    .row { display: grid; grid-template-columns: 1fr; gap: 14px; }
    @media(min-width: 900px) { .row { grid-template-columns: 1fr 1fr; } }

    /* ── PAID BADGE special ── */
    .badge-paid-on { display: inline-block; white-space: normal; line-height: 1.2; word-break: normal; }
    .paid-date-line { display: block; white-space: nowrap; }

    /* ── TOP CONTROLS layout ── */
    .top-controls { display: flex; justify-content: space-between; gap: 10px; flex-wrap: wrap; }
    .top-controls-left, .top-controls-right-top, .top-controls-right-bottom { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .top-controls-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
    .top-title-row, .top-month-row { display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; }

    /* ── INLINE PILL (sidebar items) ── */
    .sidebar .pill { display: block; margin: 0; }

    /* ── RESPONSIVE ── */
    @media(max-width: 980px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: static; }
      #top { position: static; }
    }
    @media(max-width: 700px) {
      .wrap { padding: 0 10px 24px; }
      .card { padding: 12px; }
      .field-row { grid-template-columns: 1fr; gap: 4px; }
      .overview-grid { grid-template-columns: 1fr; }
      table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
      th, td { white-space: nowrap; font-size: 11px; padding: 6px; }
      .calendar-grid { display: table !important; table-layout: fixed; width: 100%; }
      .calendar-cell { height: 100px; }
      .calendar-events { max-height: 64px; }
    }

    /* ── EXTRA UTILITY ── */
    details > summary { cursor: pointer; font-size: 13px; color: var(--purple-lite); font-weight: 600; padding: 4px 0; }
    .stack-form .actions { margin-top: 12px; }
    .top-pill-btn.pill { display: inline-flex; }

    /* Keep existing JS-compatibility class names working */
    .sidebar.card { background: transparent; border: none; box-shadow: none; padding: 0; }
    #sidebar-calculator { background: transparent; border: none; padding: 0; margin: 0; }
  </style>
</head>
<body>
<div class="wrap">
  <div class="layout">

    <!-- ═══════ SIDEBAR ═══════ -->
    <aside class="sidebar card">
      <div class="sidebar-inner">
        <div class="sidebar-brand">
          <img src="/static/brand_logo_transparent.png" alt="NorthStar logo">
          <div class="sidebar-brand-name">NorthStar <span>Ledger</span></div>
        </div>

        <div class="sidebar-section-label">Navigation</div>
        <div class="nav-links">
          <a class="pill {% if page=='dashboard' %}active{% endif %}" href="/?month={{month}}&view={{view}}&page=dashboard">⬡ Dashboard</a>
          <a class="pill {% if page in ['entries','planner'] %}active{% endif %}" href="/?month={{month}}&view={{view}}&page=entries">◈ Bills</a>
          <a class="pill {% if page=='trips' %}active{% endif %}" href="/?month={{month}}&view={{view}}&page=trips">✦ Trips / Savings</a>
          <a class="pill {% if page=='promotions' %}active{% endif %}" href="/?month={{month}}&view={{view}}&page=promotions">◉ Debt Tracker</a>
          <a class="pill {% if page=='subscriptions' %}active{% endif %}" href="/?month={{month}}&view={{view}}&page=subscriptions">↻ Subscriptions</a>
          <a class="pill {% if page=='calendar' %}active{% endif %}" href="/?month={{month}}&view={{view}}&page=calendar">▦ Calendar</a>
          <a class="pill {% if page=='checkbook' %}active{% endif %}" href="/?month={{month}}&view={{view}}&page=checkbook">⊞ History</a>
        </div>

        <!-- CALCULATOR -->
        <div class="calc-card" id="sidebar-calculator">
          <div class="calc-title">★ Calculator</div>
          <input id="rcDisplay" type="text" readonly value="0">
          <div class="calc-grid-btns">
            <button type="button" class="calc-btn op" onclick="rcClear()">C</button>
            <button type="button" class="calc-btn op" onclick="rcBack()">⌫</button>
            <button type="button" class="calc-btn op" onclick="rcAppend('%')">%</button>
            <button type="button" class="calc-btn op" onclick="rcAppend('/')">÷</button>
            <button type="button" class="calc-btn" onclick="rcAppend('7')">7</button>
            <button type="button" class="calc-btn" onclick="rcAppend('8')">8</button>
            <button type="button" class="calc-btn" onclick="rcAppend('9')">9</button>
            <button type="button" class="calc-btn op" onclick="rcAppend('*')">×</button>
            <button type="button" class="calc-btn" onclick="rcAppend('4')">4</button>
            <button type="button" class="calc-btn" onclick="rcAppend('5')">5</button>
            <button type="button" class="calc-btn" onclick="rcAppend('6')">6</button>
            <button type="button" class="calc-btn op" onclick="rcAppend('-')">−</button>
            <button type="button" class="calc-btn" onclick="rcAppend('1')">1</button>
            <button type="button" class="calc-btn" onclick="rcAppend('2')">2</button>
            <button type="button" class="calc-btn" onclick="rcAppend('3')">3</button>
            <button type="button" class="calc-btn op" onclick="rcAppend('+')">+</button>
            <button type="button" class="calc-btn" onclick="rcAppend('0')" style="grid-column:span 2">0</button>
            <button type="button" class="calc-btn" onclick="rcAppend('.')">.</button>
            <button type="button" class="calc-btn eq" onclick="rcEval()">=</button>
          </div>
        </div>
      </div>
    </aside>

    <!-- ═══════ MAIN CONTENT ═══════ -->
    <main>

      <!-- TOP BAR -->
      <div class="card dark-card" id="top" style="margin-bottom:16px">
        <div class="top-title-row" style="margin-bottom:10px">
          <div class="app-brand">
            <img src="/static/brand_logo_transparent.png" alt="NorthStar logo">
            <div class="app-brand-text">
              <div class="app-brand-name">NorthStar <span>Ledger</span></div>
              <div class="app-brand-sub">{{fmt_month_label(month)}}</div>
            </div>
          </div>
          <div class="topbar-controls">
            <button type="button" class="top-pill-btn" onclick="openSettings()">⚙ Settings</button>
            <a class="top-pill-btn" href="/logout" onclick="clearCalculatorState()">↩ Logout</a>
          </div>
        </div>

        <div class="top-month-row" style="margin-bottom:10px">
          <div class="month-nav">
            <a class="top-pill-btn" href="/?month={{prev_month}}&view={{view}}&page={{page}}">← {{fmt_month_label(prev_month)}}</a>
            <span class="month-label">{{fmt_month_label(month)}}</span>
            <a class="top-pill-btn" href="/?month={{next_month}}&view={{view}}&page={{page}}">{{fmt_month_label(next_month)}} →</a>
          </div>
          <div class="topbar-controls">
            <form id="applyRecurringForm" method="post" action="/rollover" style="display:inline">
              <input type="hidden" name="month" value="{{month}}">
              <input type="hidden" name="view" value="{{view}}">
              <input type="hidden" name="page" value="{{page}}">
              <button type="submit" class="top-pill-btn">🔁 Add Recurring Bills/Income</button>
            </form>
            <span class="household-badge">🏠 {{household_name}}</span>
          </div>
        </div>

        <div class="notes-section">
          <div class="notes-label">Notes</div>
          <form method="post" action="/dashboard-note/update" class="stack-form">
            <input type="hidden" name="month" value="{{month}}">
            <input type="hidden" name="view" value="{{view}}">
            <input type="hidden" name="page" value="{{page}}">
            <textarea name="dashboard_note_text" rows="3" placeholder="Write notes here...">{{dashboard_note_text}}</textarea>
            <div class="actions"><button type="submit" class="btn-gold">Save Notes</button></div>
          </form>
        </div>
      </div>

      <!-- DEBT CALCULATOR (promotions page) -->
      {% if page == 'promotions' %}
      <div class="card" id="credit-loan-calculator">
        <h3>Debt Calculator / Payoff</h3>
        <div class="calc-box">
          <div class="field-row"><label>Current Balance</label><input id="ccBalance" type="number" step="0.01" placeholder="0.00"></div>
          <div class="field-row"><label>APR (%)</label><input id="ccApr" type="number" step="0.01" placeholder="0.00"></div>
          <div class="field-row"><label>Payoff Timeline (months)</label><input id="ccMonths" type="number" step="1" placeholder="24"></div>
          <div class="field-row"><label>Or Monthly Payment</label><input id="ccMonthlyPay" type="number" step="0.01" placeholder="0.00"></div>
          <div class="actions">
            <button type="button" class="btn-gold" onclick="calcCreditCard()">Calculate Debt</button>
            <button type="button" class="btn-muted" onclick="resetCreditCalc()">Reset</button>
          </div>
          <div class="calc-result" id="ccResult">Enter values and click Calculate Debt.</div>
        </div>
      </div>
      {% endif %}

      <!-- DASHBOARD PAGE -->
      {% if page == 'dashboard' %}
      <div class="card">
        <h3>Overview</h3>
        <div class="overview-grid">
          <div class="stat-card balance">
            <div class="stat-card-label">Current Balance</div>
            <div class="overview-value">${{fmt_money(balance)}}</div>
          </div>
          <div class="stat-card income">
            <div class="stat-card-label">Planned Income</div>
            <div class="overview-value">${{fmt_money(income)}}</div>
          </div>
          <div class="stat-card bills">
            <div class="stat-card-label">Planned Bills</div>
            <div class="overview-value">${{fmt_money(planned_bills_total)}}</div>
          </div>
        </div>
        <div>
          {% if current_risk_balance < 0 %}
            <span class="badge badge-status-bad">⚠ Risk: Balance may go negative after unpaid bills (${{fmt_money(current_risk_balance)}})</span>
          {% else %}
            <span class="badge badge-status-ok">✓ Current balance covers bills</span>
          {% endif %}
        </div>

        <div style="margin-top:20px;padding-top:14px;border-top:1px dashed rgba(200,170,255,0.2)">
          <span class="section-title">✦ Trip / Savings Progress</span>
          <div style="display:grid;gap:12px;margin-top:10px">
            {% for t in trips %}
              {% set pct = 0 if t.target <= 0 else (t.saved / t.target * 100) %}
              <div>
                <div style="font-size:14px;font-weight:700;color:var(--purple-deep);margin-bottom:4px">
                  {{t.name}} · <span style="color:var(--purple-lite)">${{fmt_money(t.saved)}} / ${{fmt_money(t.target)}}</span>
                  <span style="color:var(--ring-pink);font-size:13px">&nbsp;{{'%.0f'|format([pct,100]|min)}}%</span>
                </div>
                <div class="progress-wrap"><div class="progress-bar" style="width:{{ [pct,100]|min }}%"></div></div>
              </div>
            {% endfor %}
          </div>
        </div>

        <div style="margin-top:20px;padding-top:14px;border-top:1px dashed rgba(200,170,255,0.2)">
          <span class="section-title">◉ Promotions Ending Soon (60 days)</span>
          {% if promotions_ending_soon|length == 0 %}
            <div style="font-size:13px;margin-top:8px" class="good">✓ No promotions in the danger window.</div>
          {% else %}
            <ul style="margin-top:10px">
              {% for p in promotions_ending_soon %}
                <li>
                  <b>{{p.card_name}}</b> — {{p.promo_name}} · ${{fmt_money(p.balance)}}
                  {% if p.days_left < 0 %}<span class="badge badge-due">Expired {{-p.days_left}}d ago</span>
                  {% elif p.days_left == 0 %}<span class="badge badge-due">Ends today</span>
                  {% else %}<span class="badge {% if p.days_left <= 14 %}badge-due{% else %}badge-paid{% endif %}">{{p.days_left}}d left</span>{% endif %}
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
      {% endif %}

      <!-- CALENDAR PAGE -->
      {% if page == 'calendar' %}
      <div class="card" id="calendar">
        <h3>Monthly Calendar</h3>
        <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:14px;font-size:13px;font-weight:600;color:var(--purple-lite)">
          <label><input type="checkbox" id="tgBill" checked onchange="applyCalendarFilters()"> Bills</label>
          <label><input type="checkbox" id="tgPromotion" checked onchange="applyCalendarFilters()"> Promotions</label>
          <label><input type="checkbox" id="tgTrip" checked onchange="applyCalendarFilters()"> Trips</label>
          <label><input type="checkbox" id="tgPaycheck" checked onchange="applyCalendarFilters()"> Paychecks</label>
          <label><input type="checkbox" id="tgSubscription" checked onchange="applyCalendarFilters()"> Subscriptions</label>
        </div>
        <table class="calendar-grid">
          <tr>
            {% for day in ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'] %}
              <th style="font-size:11px;letter-spacing:0.5px">{{day}}</th>
            {% endfor %}
          </tr>
          {% for wk in calendar_weeks %}
          <tr>
            {% for day in wk %}
              {% if day == 0 %}
                <td class="calendar-cell" style="background:#faf7ff"></td>
              {% else %}
                {% set dkey = month ~ '-' ~ ('%02d'|format(day)) %}
                {% set evs = events_by_date.get(dkey, []) %}
                <td class="calendar-cell">
                  <div style="margin-bottom:4px"><span class="calendar-day-num {% if day == today_day %}today{% endif %}">{{day}}</span></div>
                  <div class="calendar-events">
                    {% for ev in evs %}
                      {% if ev.type == 'bill' %}
                        <button type="button" class="cal-event-btn cal-event" data-type="bill" onclick="openEdit('{{ev.id}}','{{ev.due_date}}','{{ev.planned_pay_date}}','{{fmt_money(ev.amount)}}',{{1 if ev.recurring else 0}},'{{ev.recurring_timeframe or "monthly"}}','{{ev.recurring_every_months or ""}}','{{ev.recurring_end_date or ""}}',{{ev.autopay}},'{{ev.title|replace("'","\\'")}}','{{ev.paycheck_bucket}}',{{ev.paid}},'{{ev.paid_date}}')"><span class="badge badge-bill">Bill: {{ev.title}}</span></button>
                      {% elif ev.type == 'promotion' %}
                        <button type="button" class="cal-event-btn cal-event" data-type="promotion" onclick="openPromotionEdit('{{ev.id}}','{{ev.card_name|replace("'","\\'")}}','{{ev.promo_name|replace("'","\\'")}}','{{ev.start_date}}','{{ev.end_date}}','{{fmt_money(ev.balance)}}','{{ev.note|replace("'","\\'")}}')" ><span class="badge badge-promo">Promo End: {{ev.title}}</span></button>
                      {% elif ev.type == 'trip' %}
                        <button type="button" class="cal-event-btn cal-event" data-type="trip" onclick="openTripEdit('{{ev.id}}','{{ev.name|replace("'","\\'")}}','{{ev.due_month}}','{{fmt_money(ev.target)}}','{{fmt_money(ev.saved)}}')"><span class="badge badge-trip">Trip: {{ev.title}}</span></button>
                      {% elif ev.type == 'paycheck' %}
                        <button type="button" class="cal-event-btn cal-event" data-type="paycheck" onclick="openPaycheckEdit('{{ev.id}}','{{ev.title|replace("'","\\'")}}','{{ev.pay_date}}','{{fmt_money(ev.amount)}}','{{ev.income_type}}')"><span class="badge badge-paycheck">Pay: {{ev.title}}</span></button>
                      {% elif ev.type == 'subscription' %}
                        <button type="button" class="cal-event-btn cal-event" data-type="subscription" onclick="openSubscriptionEdit('{{ev.id}}','{{ev.name|replace("'","\\'")}}','{{ev.day_due}}','{{fmt_money(ev.payment)}}',{{1 if ev.recurring else 0}},'{{ev.recurring_timeframe}}','{{ev.recurring_every_months}}','{{ev.yearly_month}}')"><span class="badge badge-bill">Sub: {{ev.title}}</span></button>
                      {% endif %}
                    {% endfor %}
                  </div>
                </td>
              {% endif %}
            {% endfor %}
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}

      <!-- ENTRIES / BILLS PAGE -->
      {% if page == 'entries' %}
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:14px;margin-bottom:16px">

        <div class="card" id="promotion-alerts" style="margin:0">
          <h3>Promotion Alerts</h3>
          {% if promotions_ending_soon|length == 0 %}
            <p class="good">✓ No promotions expiring in the next 60 days.</p>
          {% else %}
            <ul>{% for p in promotions_ending_soon %}<li><b>{{p.card_name}}</b> — {{p.promo_name}}
              {% if p.days_left < 0 %}<span class="badge badge-due">Expired {{-p.days_left}}d ago</span>
              {% elif p.days_left == 0 %}<span class="badge badge-due">Ends today</span>
              {% else %}<span class="badge {% if p.days_left <= 14 %}badge-due{% else %}badge-paid{% endif %}">{{p.days_left}}d left</span>{% endif %}
            </li>{% endfor %}</ul>
          {% endif %}
        </div>

        <div class="card" id="due-now" style="margin:0">
          <h3>Due Now</h3>
          <div style="margin-bottom:8px"><span class="badge badge-due">Due Now: {{due_now_bills|length}}</span></div>
          {% if due_now_bills|length == 0 %}
            <div class="good" style="font-size:13px">No bills due today.</div>
          {% else %}
            <ul>{% for b in due_now_bills %}<li><b>{{b.name}}</b> · {{fmt_date(b.due_date)}} · ${{fmt_money(b.amount)}}</li>{% endfor %}</ul>
          {% endif %}
        </div>

        <div class="card" id="past-due" style="margin:0">
          <h3>Past Due</h3>
          <div style="margin-bottom:8px"><span class="badge badge-due">Past Due: {{past_due_bills|length}}</span></div>
          {% if past_due_bills|length == 0 %}
            <div class="good" style="font-size:13px">No past-due bills.</div>
          {% else %}
            <ul>{% for b in past_due_bills %}<li><b>{{b.name}}</b> · {{fmt_date(b.due_date)}} · ${{fmt_money(b.amount)}} <span class="badge badge-due">{{b.days_past_due}}d late</span></li>{% endfor %}</ul>
          {% endif %}
        </div>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:14px;margin-bottom:16px">
        <div class="card" id="projection" style="margin:0">
          <h3>No-Negative Projection</h3>
          <p style="font-size:13px;margin-bottom:8px"><b>Starting:</b> ${{fmt_money(projection.starting)}} | <b>Min Buffer:</b> ${{fmt_money(projection.min_buffer)}}</p>
          {% if projection.first_negative %}
            <p class="bad">⚠ Goes negative on {{fmt_date(projection.first_negative[0])}} at {{projection.first_negative[1]}} ({{fmt_money(projection.first_negative[2])}})</p>
          {% elif projection.first_below_buffer %}
            <p class="warn">⚠ Drops below buffer on {{fmt_date(projection.first_below_buffer[0])}} at {{projection.first_below_buffer[1]}} ({{fmt_money(projection.first_below_buffer[2])}})</p>
          {% else %}
            <p class="good">✓ Stays above buffer with current plan.</p>
          {% endif %}
          <details><summary>Show projected timeline</summary>
            <ul>{% for t in projection.timeline %}<li>{{fmt_date(t[0])}} — {{t[1]}} — {{'%+.2f'|format(t[2])}} => <b>{{fmt_money(t[3])}}</b></li>{% endfor %}</ul>
          </details>
        </div>

        <div class="card" id="savings-needed" style="margin:0">
          <h3>Savings Needed / Month</h3>
          {% if savings_goal_monthly|length == 0 %}
            <div class="good" style="font-size:13px">No trip/activity targets set.</div>
          {% else %}
            <ul>{% for t in savings_goal_monthly %}<li><b>{{t.name}}</b> · Remaining ${{fmt_money(t.remaining)}} · {{t.months_left}} mo left · <span class="badge badge-paid">${{fmt_money(t.monthly_needed)}} /mo</span></li>{% endfor %}</ul>
          {% endif %}
        </div>
      </div>
      {% endif %}

      <!-- TRIPS PAGE -->
      {% if page == 'trips' %}
      <div class="card" id="trips">
        <h3>Trips / Activities</h3>
        <form method="post" action="/trips/add" class="stack-form">
          <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
          <div class="field-row"><label>Name</label><input name="name" placeholder="e.g. Summer Trip" required></div>
          <div class="field-row"><label>Due Date</label><input type="date" name="due_month" required></div>
          <div class="field-row"><label>Target Amount</label><input type="number" step="0.01" name="target" placeholder="0.00" required></div>
          <div class="field-row"><label>Already Saved</label><input type="number" step="0.01" name="saved" placeholder="0.00" value="0"></div>
          <div class="actions"><button class="btn-gold">Add Trip</button></div>
        </form>
        <div style="margin-top:16px;display:grid;gap:12px">
          {% for t in trips %}
            {% set pct = 0 if t.target <= 0 else (t.saved / t.target * 100) %}
            <div class="trip-card">
              <div class="trip-card-header">
                <div class="trip-card-name">{{t.name}}</div>
                <div class="trip-card-due">Due {{fmt_date(t.due_month)}}</div>
              </div>
              <div class="trip-stats-grid">
                <div><div class="trip-stat-label">Target</div><div class="trip-stat-val">${{fmt_money(t.target)}}</div></div>
                <div><div class="trip-stat-label">Saved</div><div class="trip-stat-val">${{fmt_money(t.saved)}}</div></div>
                <div><div class="trip-stat-label">Remaining</div><div class="trip-stat-val">${{fmt_money(t.target-t.saved)}}</div></div>
              </div>
              <div class="progress-wrap"><div class="progress-bar" style="width:{{ [pct,100]|min }}%"></div></div>
              <div class="progress-label" style="margin-bottom:10px">{{'%.0f'|format([pct,100]|min)}}% funded</div>
              <div style="display:flex;gap:8px;flex-wrap:wrap">
                <button type="button" onclick="openTripEdit('{{t.id}}','{{t.name|replace("'","\\'")}}','{{ t.due_month if (t.due_month|length > 7) else (t.due_month ~ "-01") }}','{{fmt_money(t.target)}}','{{fmt_money(t.saved)}}')">Edit</button>
                <button type="button" onclick="openTripContrib('{{t.id}}','{{t.name|replace("'","\\'")}}')">Add Contribution</button>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="card" id="savings-widget">
        <h3>Savings</h3>
        <p style="font-size:13.5px"><b>Saved this month (paid savings bills):</b> ${{fmt_money(savings_paid_month)}}</p>
        <p style="font-size:13.5px"><b>Planned savings bills this month:</b> ${{fmt_money(savings_planned_month)}}</p>
        <p style="font-size:12px;color:#6a5a8a;margin-top:8px">Tip: In Bills/Paycheck Planner, add or edit a bill and choose category <b>savings</b> to track savings contributions here.</p>
      </div>
      {% endif %}

      <!-- PROMOTIONS PAGE -->
      {% if page == 'promotions' %}
      <div class="card" id="promotions">
        <h3>Promotions Tracker</h3>
        <form method="post" action="/promotions/add" class="stack-form">
          <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:8px">
            <div class="promo-inline"><label>Card / Account</label><input name="card_name" placeholder="Card / Account" required></div>
            <div class="promo-inline"><label>Promotion</label><input name="promo_name" placeholder="e.g. 12 month no interest" required></div>
            <div class="promo-inline"><label>Start Date</label><input type="date" name="start_date"></div>
            <div class="promo-inline"><label>End Date</label><input type="date" name="end_date" required></div>
            <div class="promo-inline"><label>Promo Balance</label><input type="number" step="0.01" name="balance" placeholder="0.00" required></div>
            <div class="promo-inline"><label>Note</label><input name="note" placeholder="optional"></div>
          </div>
          <div class="actions"><button class="btn-gold">Add Promotion</button></div>
        </form>
        <table class="adaptive-table" style="margin-top:14px">
          <colgroup><col><col><col><col><col><col><col style="width:72px"><col style="width:90px"></colgroup>
          <tr><th>Account</th><th>Promotion</th><th>Start</th><th>End</th><th>Total</th><th>Status</th><th>Edit</th><th>Complete</th></tr>
          {% for p in promotions %}
          {% set ns = namespace(days='n/a') %}
          {% for w in promotions_ending_soon %}{% if w.id == p.id %}{% set ns.days = w.days_left %}{% endif %}{% endfor %}
          <tr>
            <td>{{p.card_name}}</td>
            <td>{{p.promo_name}}{% if p.note %}<div style="font-size:11px;color:var(--purple-lite)">{{p.note}}</div>{% endif %}</td>
            <td>{{fmt_date(p.start_date)}}</td>
            <td>{{fmt_date(p.end_date)}}</td>
            <td>${{fmt_money(p.balance)}}</td>
            <td>
              {% if p.completed %}<span class="badge badge-paid">Completed</span>
              {% elif ns.days == 'n/a' %}<span class="badge badge-paid">On track</span>
              {% elif ns.days < 0 %}<span class="badge badge-due">Expired {{-ns.days}}d ago</span>
              {% elif ns.days == 0 %}<span class="badge badge-due">Ends today</span>
              {% elif ns.days <= 14 %}<span class="badge badge-due">{{ns.days}}d left</span>
              {% else %}<span class="badge badge-paid">{{ns.days}}d left</span>{% endif %}
            </td>
            <td><button class="btn-sm" type="button" onclick="openPromotionEdit('{{p.id}}','{{p.card_name|replace("'","\\'")}}','{{p.promo_name|replace("'","\\'")}}','{{p.start_date or ''}}','{{p.end_date}}','{{fmt_money(p.balance)}}','{{(p.note or '')|replace("'","\\'")}}')" >Edit</button></td>
            <td>
              {% if p.completed %}
                <form method="post" action="/promotions/reopen/{{p.id}}"><input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><button class="btn-sm btn-muted" type="submit">Reopen</button></form>
              {% else %}
                <form method="post" action="/promotions/complete/{{p.id}}"><input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><button class="btn-sm" type="submit">Complete</button></form>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </table>

        <!-- Credit Card Tracker -->
        <div id="credit-card-tracker" style="margin-top:20px;padding-top:14px;border-top:1px dashed rgba(200,170,255,0.2)">
          <h3>Credit Card Tracker</h3>
          <form method="post" action="/credit/add" class="stack-form">
            <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input type="hidden" name="anchor" value="credit-card-tracker">
            <div class="field-row"><label>Credit Card Name</label><input name="card_name" required></div>
            <div class="field-row"><label>Interest Rate (%)</label><input type="number" step="0.01" name="interest_rate" placeholder="0.00"></div>
            <div class="field-row"><label>Credit Limit</label><input type="number" step="0.01" name="credit_limit" placeholder="0.00"></div>
            <div class="actions"><button class="btn-gold">Add Credit Account</button></div>
          </form>
          <table class="adaptive-table" style="margin-top:12px">
            <colgroup><col><col><col><col><col style="width:72px"><col style="width:90px"></colgroup>
            <tr><th>Card Name</th><th>Interest Rate</th><th>Credit Limit</th><th>Status</th><th>Edit</th><th>Action</th></tr>
            {% for cc in credit_accounts %}
            <tr>
              <td>{{cc.card_name}}</td><td>{{fmt_money(cc.interest_rate)}}%</td><td>${{fmt_money(cc.credit_limit)}}</td>
              <td>{% if cc.paid_off %}<span class="badge badge-paid">No Balance</span>{% else %}<span class="badge badge-due">Open</span>{% endif %}</td>
              <td><button class="btn-sm" type="button" onclick="openCreditEdit('{{cc.id}}','{{cc.card_name|replace("'","\\'")}}','{{'%.2f'|format(cc.interest_rate or 0)}}','{{'%.2f'|format(cc.credit_limit or 0)}}',{{1 if cc.paid_off else 0}})">Edit</button></td>
              <td><form method="post" action="/credit/toggle-paid/{{cc.id}}" style="display:inline"><input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input type="hidden" name="anchor" value="credit-card-tracker"><button class="btn-sm" type="submit">{% if cc.paid_off %}Reopen{% else %}Paid Off{% endif %}</button></form></td>
            </tr>
            {% endfor %}
          </table>
        </div>

        <!-- Loans Tracker -->
        <div id="loans-tracker" style="margin-top:20px;padding-top:14px;border-top:1px dashed rgba(200,170,255,0.2)">
          <h3>Loans Tracker</h3>
          <form method="post" action="/loans/add" class="stack-form">
            <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input type="hidden" name="anchor" value="loans-tracker">
            <div class="field-row"><label>Loan Name</label><input name="loan_name" required></div>
            <div class="field-row"><label>Interest Rate (%)</label><input type="number" step="0.01" name="interest_rate" placeholder="0.00"></div>
            <div class="field-row"><label>Loan Amount</label><input type="number" step="0.01" name="loan_amount" placeholder="0.00"></div>
            <div class="field-row"><label>End Date</label><input type="date" name="end_date"></div>
            <div class="field-row"><label>Note</label><input type="text" name="note" maxlength="24" placeholder="Optional note (24 max)"></div>
            <div class="actions"><button class="btn-gold">Add Loan</button></div>
          </form>
          <table class="adaptive-table" style="margin-top:12px">
            <colgroup><col><col><col><col><col><col><col style="width:72px"><col style="width:90px"></colgroup>
            <tr><th>Loan Name</th><th>Interest Rate</th><th>Loan Amount</th><th>End Date</th><th>Note</th><th>Status</th><th>Edit</th><th>Action</th></tr>
            {% for ln in loans %}{% if not ln.paid_off %}
            <tr {% if ln.end_date and ln.end_date <= month_last_day %}style="background:#e9f9ee"{% endif %}>
              <td>{{ln.loan_name}}</td><td>{{fmt_money(ln.interest_rate)}}%</td><td>${{fmt_money(ln.loan_amount)}}</td>
              <td>{{fmt_date(ln.end_date) if ln.end_date else '—'}}</td><td>{{ln.note or '—'}}</td>
              <td><span class="badge badge-due">Open</span></td>
              <td><button class="btn-sm" type="button" onclick="openLoanEdit('{{ln.id}}','{{ln.loan_name|replace("'","\\'")}}','{{'%.2f'|format(ln.interest_rate or 0)}}','{{'%.2f'|format(ln.loan_amount or 0)}}','{{(ln.note or '')|replace("'","\\'")}}','{{ln.end_date or ''}}')">Edit</button></td>
              <td><form method="post" action="/loans/toggle-paid/{{ln.id}}"><input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input type="hidden" name="anchor" value="loans-tracker"><button class="btn-sm" type="submit">Paid Off</button></form></td>
            </tr>
            {% endif %}{% endfor %}
          </table>
        </div>
      </div>
      {% endif %}

      <!-- SUBSCRIPTIONS PAGE -->
      {% if page == 'subscriptions' %}
      <div class="card" id="subscriptions">
        <h3>Subscriptions</h3>
        <form method="post" action="/subscriptions/add" class="stack-form">
          <input type="hidden" name="_csrf" value="{{ csrf_token }}">
          <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
          <div class="field-row"><label>Subscription Name</label><input name="name" required></div>
          <div class="field-row"><label>Day Due</label><input type="number" min="1" max="31" name="day_due" required></div>
          <div class="field-row"><label>Payment</label><input type="number" step="0.01" name="payment" required></div>
          <div class="field-row"><label>Recurring</label><div><input type="checkbox" name="recurring" checked onchange="toggleSubscriptionRecurring(this)"> recurring</div></div>
          <div class="field-row sub-recurring-fields"><label>Timeframe</label><select name="recurring_timeframe" onchange="toggleSubscriptionTimeframe(this)"><option value="monthly" selected>Monthly</option><option value="yearly">Yearly</option><option value="specified_months">Specified # months</option></select></div>
          <div class="field-row sub-yearly-month" style="display:none"><label>Yearly Month</label><select name="yearly_month"><option value="1">January</option><option value="2">February</option><option value="3">March</option><option value="4">April</option><option value="5">May</option><option value="6">June</option><option value="7">July</option><option value="8">August</option><option value="9">September</option><option value="10">October</option><option value="11">November</option><option value="12">December</option></select></div>
          <div class="field-row sub-recurring-months" style="display:none"><label>Every # Months</label><input type="number" min="1" step="1" name="recurring_every_months" placeholder="e.g. 3"></div>
          <div class="actions"><button class="btn-gold">Add Subscription</button></div>
        </form>
        <table class="adaptive-table" style="margin-top:14px">
          <tr><th>Name</th><th>Day Due</th><th>Payment</th><th>Recurring</th><th>Type</th><th>Edit</th></tr>
          {% for s in subscriptions %}
          <tr>
            <td>{{s.name}}</td><td>{{s.day_due}}</td><td>${{'%.2f'|format(s.payment or 0)}}</td>
            <td>{% if (s.recurring or 0) %}<span class="badge badge-paid">YES</span>{% else %}<span class="badge badge-due">NO</span>{% endif %}</td>
            <td>{% if not (s.recurring or 0) %}—{% elif (s.recurring_timeframe or 'monthly') == 'yearly' %}Yearly{% elif (s.recurring_timeframe or 'monthly') == 'specified_months' %}Every {{s.recurring_every_months or 1}} mo{% else %}Monthly{% endif %}</td>
            <td><button class="btn-sm" type="button" onclick="openSubscriptionEdit('{{s.id}}','{{s.name|replace("'","\\'")}}','{{s.day_due}}','{{'%.2f'|format(s.payment or 0)}}',{{1 if (s.recurring or 0) else 0}},'{{s.recurring_timeframe or "monthly"}}','{{s.recurring_every_months or ""}}','{{s.yearly_month or ""}}')">Edit</button></td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}

      <!-- ENTRIES PAYCHECK VIEW -->
      {% if page == 'entries' %}
      {% if view == 'paycheck' %}
      <div class="card" id="planner">
        <h3 style="display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap">
          <span style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
            Paycheck Planner
            <a class="pill" href="/?month={{month}}&view=paycheck&page={{page}}" style="font-size:12px;padding:4px 10px">Per Paycheck</a>
            <a class="pill" href="/?month={{month}}&view=checklist&page={{page}}" style="font-size:12px;padding:4px 10px">Checklist</a>
          </span>
          <button type="button" onclick="openPaycheckManager()">Edit Paychecks/Income</button>
        </h3>
        <p style="margin:0 0 14px"><span class="badge badge-paid">Rollover from {{fmt_month_label(prev_month)}}: ${{fmt_money(month_start)}}</span></p>
        <h3>Add Income / Debt</h3>
        <form method="post" action="/entries/add" style="margin-bottom:14px">
          <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
          <select id="entryType" name="entry_type" onchange="onEntryTypeChange()"><option value="income">Income</option><option value="bill" selected>Bill/Debt</option><option value="trip_contribution">Trip Contribution</option></select>
          <div id="incomeFields" style="display:none"><select name="income_kind" id="incomeKind" onchange="onIncomeKindChange()"><option value="paycheck">Paycheck</option><option value="other">Other Income</option></select><input name="owner" id="incomeOwner" placeholder="Owner"><span class="date-hint-wrap" id="incomePayDateWrap"><input type="date" id="incomePayDate" name="pay_date"><span class="date-hint"></span></span><input type="number" step="0.01" name="income_amount" placeholder="Amount"></div>
          <div id="billFields" style="display:none"><input name="name" placeholder="Name"><input type="date" name="due_date"><input type="number" step="0.01" name="bill_amount" placeholder="Amount"><label><input type="checkbox" name="recurring" onchange="toggleEntryRecurringEnd(this)"> recurring</label><span class="entry-recurring-end" style="display:none"><input type="date" name="recurring_end_date"></span><label><input type="checkbox" name="autopay"> autopay</label></div>
          <div id="tripContributionFields" style="display:none"><select name="contrib_trip_id">{% for t in trips %}<option value="{{t.id}}">{{t.name}}</option>{% endfor %}</select><input type="date" name="contrib_date"><input type="number" step="0.01" name="contrib_amount" placeholder="Amount"></div>
          <button class="btn-gold">Add</button>
        </form>
        {% for pk in paycheck_plan %}
        <div style="border:1px solid var(--tint-mid);border-radius:var(--radius-sm);padding:14px;margin-bottom:14px;background:var(--card-bg-tint)">
          <p style="margin:0 0 10px"><b>{{pk['display_label']}}</b>{% if pk['date'] %} — {{fmt_date(pk['date'])}} ({{pk['owner']}}){% endif %} | Amount: <b>${{fmt_money(pk['paycheck_amount'])}}</b> | Available: <b>${{fmt_money(pk['starting_available'])}}</b>{% if pk['income_type']=='last_month' %} <button type="button" class="btn-sm" onclick="openStartOverride('{{month}}','{{fmt_money(pk['starting_available'])}}')">Edit</button>{% endif %}</p>
          <table class="planner-table">
            <tr><th>Due / Planned</th><th>Name</th><th>Category</th><th>Amount</th><th>Running Balance</th><th>Recurring</th><th>Status</th><th>AutoPay</th><th>Edit</th><th>Action</th></tr>
            {% for pass_paid in [1,0] %}{% for it in pk['items'] %}
            {% if (pass_paid == 1 and it['is_paid']) or (pass_paid == 0 and not it['is_paid']) %}
            <tr {% if it['is_paid'] %}style="background:#e9f9ee"{% elif it['is_postponed'] %}style="background:#fffde7"{% endif %}>
              <td><div>{{fmt_date(it['bill']['due_date'])}}</div>{% if it['bill']['planned_pay_date'] and it['bill']['planned_pay_date'] != it['bill']['due_date'] %}<div style="font-size:11px;color:#7a5a00">Planned: {{fmt_date(it['bill']['planned_pay_date'])}}</div>{% endif %}</td>
              <td>{{it['bill']['name']}}{% if it['bill']['note'] %}<div style="font-size:11px;color:#7a5a00">📝 {{it['bill']['note']}}</div>{% endif %}</td>
              <td>{{it['bill']['category']}}</td>
              <td>${{fmt_money(it['amount'])}}</td>
              <td>${{fmt_money(it['running_after'])}}</td>
              <td>{% if it['bill']['recurring'] %}YES{% else %}NO{% endif %}</td>
              <td>{% if it['is_paid'] %}<span class="badge badge-paid">PAID</span>{% elif it['is_postponed'] %}<span class="badge" style="background:#fff1a8;color:#7a5a00">POSTPONED</span>{% elif it['can_pay'] %}<span class="badge badge-paid">OK</span>{% else %}<span class="badge badge-due">NEGATIVE</span>{% endif %}</td>
              <td>{% if it['bill']['autopay'] %}<span class="badge badge-paid">AUTO</span>{% else %}<span class="badge badge-due">MANUAL</span>{% endif %}</td>
              <td>
                {% if (it['bill']['id']|int) >= 1000000 %}
                  <button class="btn-sm" type="button" onclick="openLedgerEdit('{{ (it['bill']['id']|int) - 1000000 }}','{{it['bill']['due_date']}}','{{it['bill']['name']|replace("'","\\'")}}','-{{"%.2f"|format(it["amount"])}}','trip contribution')">Edit</button>
                {% else %}
                  <button class="btn-sm" type="button" onclick="openEdit('{{it['bill']['id']}}','{{it['bill']['due_date']}}','{{it['bill']['planned_pay_date'] or it['bill']['due_date']}}','{{"%.2f"|format(it["amount"])}}',{{1 if it['bill']['recurring'] else 0}},'{{it['bill']['recurring_timeframe'] or "monthly"}}','{{it['bill']['recurring_every_months'] or ""}}','{{it['bill']['recurring_end_date'] or ""}}',{{1 if it['bill']['autopay'] else 0}},'{{it['bill']['name']|replace("'","\\'")}}','{{it['bill']['paycheck_bucket'] if it['bill']['paycheck_bucket'] is not none else ""}}',{{1 if it['bill']['paid'] else 0}},'{{it['bill']['paid_date'] or ""}}')">Edit</button>
                {% endif %}
              </td>
              <td>
                {% if (it['bill']['id']|int) >= 1000000 %}
                  <span class="badge badge-paid">✓</span>
                {% elif not it['is_paid'] %}
                  <div style="display:grid;gap:4px">
                    <form method="post" action="/bills/toggle/{{it['bill']['id']}}" style="margin:0"><input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><button type="submit" class="btn-sm" style="background:#dff6df;color:#1f5d1f;border:1px solid #bde7bd;width:100%">☑ Paid</button></form>
                    <button type="button" class="btn-sm" onclick="openPostponeModal('{{it['bill']['id']}}','{{it['bill']['planned_pay_date'] or it['bill']['due_date']}}')" style="background:#fff9d9;color:#7a5a00;border:1px solid #f2e4a3">Postpone</button>
                  </div>
                {% else %}
                  <span class="badge badge-paid badge-paid-on">Paid on:<span class="paid-date-line">{{fmt_date(it['bill']['paid_date']) if it['bill']['paid_date'] else '—'}}</span></span>
                {% endif %}
              </td>
            </tr>
            {% endif %}{% endfor %}{% endfor %}
          </table>
          <p style="margin-top:10px"><b>End of {{pk['display_label']|lower}} projected:</b> ${{fmt_money(pk['ending_balance'])}} {% if pk['goes_negative'] %}<span class="badge badge-due">Needs adjustment</span>{% else %}<span class="badge badge-paid">Good</span>{% endif %}</p>
        </div>
        {% endfor %}
        <div class="card" id="prior-pay-carry-widget" style="margin-top:0;background:var(--card-bg-tint)">
          <h3 style="margin-top:0">Next Month Bills Due This Last Check</h3>
          {% if next_month_carry_bills|length == 0 %}
            <div class="good" style="font-size:13px">No next-month bills assigned to this last check.</div>
          {% else %}
            <ul>{% for b in next_month_carry_bills %}<li><b>{{b.name}}</b> {{fmt_date(b.due_date)}} · ${{fmt_money(b.amount)}}</li>{% endfor %}</ul>
          {% endif %}
          <div style="margin-top:10px;background:#fdf0fa;border:1px solid #f5c2dc;border-radius:10px;padding:10px">
            <p style="margin:0;font-size:13.5px"><b>Projected ending balance until next pay:</b> ${{fmt_money(carry_after_balance)}}
              {% if carry_after_balance < 0 %}<span class="badge badge-due">Negative</span>{% else %}<span class="badge badge-paid">Good</span>{% endif %}
            </p>
          </div>
        </div>
      </div>
      {% endif %}

      <!-- CHECKLIST VIEW -->
      {% if view == 'checklist' %}
      <div class="card" id="unpaid-checklist">
        <h3>Unpaid Bills Checklist</h3>
        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px">
          <a class="pill" href="/?month={{month}}&view=paycheck&page={{page}}" style="font-size:12px;padding:4px 12px">Per Paycheck</a>
          <a class="pill" href="/?month={{month}}&view=checklist&page={{page}}" style="font-size:12px;padding:4px 12px">Checklist</a>
        </div>
        <h3>Add Income / Debt</h3>
        <form method="post" action="/entries/add" style="margin-bottom:14px">
          <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
          <select id="entryType" name="entry_type" onchange="onEntryTypeChange()"><option value="income">Income</option><option value="bill" selected>Bill/Debt</option><option value="trip_contribution">Trip Contribution</option></select>
          <div id="incomeFields" style="display:none"><select name="income_kind" id="incomeKind" onchange="onIncomeKindChange()"><option value="paycheck">Paycheck</option><option value="other">Other Income</option></select><input name="owner" id="incomeOwner" placeholder="Owner"><span class="date-hint-wrap" id="incomePayDateWrap"><input type="date" id="incomePayDate" name="pay_date"><span class="date-hint"></span></span><input type="number" step="0.01" name="income_amount" placeholder="Amount"></div>
          <div id="billFields" style="display:none"><input name="name" placeholder="Name"><input type="date" name="due_date"><input type="number" step="0.01" name="bill_amount" placeholder="Amount"><label><input type="checkbox" name="recurring" onchange="toggleEntryRecurringEnd(this)"> recurring</label><span class="entry-recurring-end" style="display:none"><input type="date" name="recurring_end_date"></span><label><input type="checkbox" name="autopay"> autopay</label></div>
          <div id="tripContributionFields" style="display:none"><select name="contrib_trip_id">{% for t in trips %}<option value="{{t.id}}">{{t.name}}</option>{% endfor %}</select><input type="date" name="contrib_date"><input type="number" step="0.01" name="contrib_amount" placeholder="Amount"></div>
          <button class="btn-gold">Add</button>
        </form>
        <table class="planner-table">
          <tr><th>Due</th><th>Name</th><th>Category</th><th>Recurring</th><th>Amount</th><th>Status</th><th>Paycheck</th><th>AutoPay</th><th>Edit</th><th>Mark Paid</th></tr>
          {% for b in unpaid_bills_all %}
          <tr {% if b.is_postponed %}style="background:#fffde7"{% endif %}>
            <td>{{fmt_date(b.due_date)}}</td>
            <td>{{b.name}}{% if b.note %}<div style="font-size:11px;color:#7a5a00">📝 {{b.note}}</div>{% endif %}</td>
            <td>{{b.category}}</td>
            <td>{% if b.recurring %}YES{% else %}NO{% endif %}</td>
            <td>${{fmt_money(b.amount)}}</td>
            <td>{% if b.is_postponed %}<span class="badge" style="background:#fff1a8;color:#7a5a00">POSTPONED</span>{% else %}<span class="badge badge-due">DUE</span>{% endif %}</td>
            <td>#{{buckets[b.id][0]}} ({{fmt_date(buckets[b.id][2])}})</td>
            <td>{% if b.autopay %}<span class="badge badge-paid">AUTO</span>{% else %}<span class="badge badge-due">MANUAL</span>{% endif %}</td>
            <td><button class="btn-sm" type="button" onclick="openEdit('{{b.id}}','{{b.due_date}}','{{b.planned_pay_date or b.due_date}}','{{"%.2f"|format(b.amount)}}',{{1 if b.recurring else 0}},'{{b.recurring_timeframe or "monthly"}}','{{b.recurring_every_months or ""}}','{{b.recurring_end_date or ""}}',{{1 if b.autopay else 0}},'{{b.name|replace("'","\\'")}}','{{b.paycheck_bucket if b.paycheck_bucket is not none else ""}}',{{1 if b.paid else 0}},'{{b.paid_date or ""}}')">Edit</button></td>
            <td>
              <div style="display:grid;gap:4px">
                <form method="post" action="/bills/toggle/{{b.id}}" style="margin:0"><input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><button type="submit" class="btn-sm" style="background:#dff6df;color:#1f5d1f;border:1px solid #bde7bd;width:100%">☑ Paid</button></form>
                <button type="button" class="btn-sm" onclick="openPostponeModal('{{b.id}}','{{b.planned_pay_date or b.due_date}}')" style="background:#fff9d9;color:#7a5a00;border:1px solid #f2e4a3">Postpone</button>
              </div>
            </td>
          </tr>
          {% endfor %}
        </table>
        <p style="margin-top:10px;font-size:12.5px"><span class="badge badge-paid">PAID</span> items disappear from this checklist and stay logged in History.</p>
      </div>
      {% endif %}
      {% endif %}

      <!-- CHECKBOOK / HISTORY -->
      {% if page == 'checkbook' %}
      <div class="card" id="checkbook">
        <h3>History</h3>
        <form method="post" action="/ledger/add" style="margin-bottom:14px">
          <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
          <input type="date" name="tx_date" required>
          <input name="label" placeholder="Label" required>
          <input type="number" step="0.01" name="amount" placeholder="Use negative for spend" required>
          <input name="note" placeholder="Note">
          <button class="btn-gold">Add Entry</button>
        </form>
        <table class="adaptive-table" style="margin-top:10px">
          <tr><th>Paid Date</th><th>Label</th><th>Amount</th><th>Note</th><th>Running Balance</th><th>Edit</th></tr>
          {% for t in ledger_running %}
          <tr>
            <td>{{fmt_date(t[1])}}</td><td>{{t[2]}}</td><td>{{'%+.2f'|format(t[3])}}</td><td>{{t[4]}}</td><td><b>${{fmt_money(t[5])}}</b></td>
            <td><button class="btn-sm" type="button" onclick="openLedgerEdit('{{t[0]}}','{{t[1]}}','{{t[2]|replace("'","\\'")}}','{{fmt_money(t[3])}}','{{(t[4] or "")|replace("'","\\'")}}')" >Edit</button></td>
          </tr>
          {% endfor %}
        </table>
        <p style="margin-top:10px;font-size:14px"><b>Ending Balance:</b> ${{fmt_money(balance)}}</p>

        <div style="margin-top:18px;padding-top:12px;border-top:1px dashed rgba(200,170,255,0.2)">
          <h3>Completed Promotions</h3>
          <table class="adaptive-table" style="margin-top:10px">
            <tr><th>Account</th><th>Promotion</th><th>Start</th><th>End</th><th>Total</th><th>Status</th></tr>
            {% for p in completed_promotions %}<tr><td>{{p.card_name}}</td><td>{{p.promo_name}}</td><td>{{fmt_date(p.start_date)}}</td><td>{{fmt_date(p.end_date)}}</td><td>${{fmt_money(p.balance)}}</td><td><span class="badge badge-paid">Completed</span></td></tr>{% endfor %}
          </table>
        </div>

        <div style="margin-top:18px;padding-top:12px;border-top:1px dashed rgba(200,170,255,0.2)">
          <h3>Paid-Off Loans</h3>
          <table class="adaptive-table" style="margin-top:10px">
            <tr><th>Loan Name</th><th>Interest Rate</th><th>Loan Amount</th><th>Status</th></tr>
            {% for ln in paid_loans %}<tr><td>{{ln.loan_name}}</td><td>{{fmt_money(ln.interest_rate)}}%</td><td>${{fmt_money(ln.loan_amount)}}</td><td><span class="badge badge-paid">Paid Off</span></td></tr>{% endfor %}
          </table>
        </div>
      </div>
      {% endif %}

    </main>
  </div>
</div>

<!-- ═══════ MODALS ═══════ -->

<!-- Edit Bill -->
<div id="editModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Edit Bill</h3>
    <form id="editForm" class="stack-form" method="post" action="">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <div class="field-row"><label>Name</label><input id="editName" type="text" name="name" required></div>
      <div class="field-row"><label>Paycheck Bucket</label><select id="editPaycheck" name="paycheck_bucket"><option value="">Auto (by due date)</option>{% for p in paychecks %}<option value="{{loop.index}}">#{{loop.index}} — {{fmt_date(p.pay_date)}} ({{p.owner}})</option>{% endfor %}</select></div>
      <div class="field-row"><label>Due Date</label><input id="editDue" type="date" name="due_date" required></div>
      <div class="field-row"><label>Planned Pay Date</label><input id="editPlannedPay" type="date" name="planned_pay_date"></div>
      <div class="field-row"><label>Amount</label><input id="editAmount" type="number" step="0.01" name="amount" required></div>
      <div class="field-row"><label>Recurring</label><div><input id="editRecurring" type="checkbox" name="recurring" onchange="toggleBillRecurringOptions()"> recurring payment</div></div>
      <div id="editRecurringOptions" style="display:none">
        <div class="field-row"><label>Timeframe</label><select id="editRecurringTimeframe" name="recurring_timeframe" onchange="toggleBillRecurringOptions()"><option value="monthly">Monthly</option><option value="yearly">Yearly</option><option value="specified_months">Specified # months</option></select></div>
        <div class="field-row" id="editRecurringMonthsRow" style="display:none"><label>Every # Months</label><input id="editRecurringEveryMonths" type="number" min="1" step="1" name="recurring_every_months"></div>
        <div class="field-row" id="editRecurringEndDateRow" style="display:none"><label>End Date</label><input id="editRecurringEndDate" type="date" name="recurring_end_date"></div>
      </div>
      <div class="field-row"><label>AutoPay</label><div><input id="editAutopay" type="checkbox" name="autopay"> autopay</div></div>
      <div class="field-row"><label>Paid</label><div><input id="editPaid" type="checkbox" name="paid"> paid</div></div>
      <div class="field-row"><label>Paid Date</label><input id="editPaidDate" type="date" name="paid_date"></div>
      <div class="actions"><button type="submit" class="btn-gold">Save</button><button type="button" onclick="closeEdit()" class="btn-muted">Cancel</button></div>
    </form>
    <form id="deleteBillForm" method="post" action="" style="margin-top:10px" onsubmit="return confirmDelete('this bill')">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <button type="submit" class="btn-danger">Delete Bill</button>
    </form>
  </div>
</div>

<!-- Postpone -->
<div id="postponeModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Postpone Bill</h3>
    <form id="postponeForm" class="stack-form" method="post" action="">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <input type="hidden" id="removePostponeFlag" name="remove_postpone" value="0">
      <div class="field-row"><label>New Planned Pay Date</label><input id="postponeDate" type="date" name="postpone_date"></div>
      <div class="field-row"><label>Postpone Note</label><input id="postponeNote" type="text" name="postpone_note" placeholder="Why postponing?"></div>
      <div class="actions">
        <button type="submit" class="btn-gold">Save Postpone</button>
        <button type="button" onclick="submitRemovePostpone()" style="background:#fff9d9;color:#7a5a00;border:1px solid #f2e4a3">Remove Postpone</button>
        <button type="button" onclick="closePostponeModal()" class="btn-muted">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- Paycheck Manager -->
<div id="paycheckManagerModal" class="modal-overlay">
  <div class="modal-box modal-wide">
    <h3>Edit Paychecks / Income</h3>
    <table class="adaptive-table">
      <tr><th>Type</th><th>Owner</th><th>Date</th><th>Amount</th><th>Action</th></tr>
      {% for p in paychecks %}<tr><td>{% if (p.income_type or 'paycheck') == 'other' %}Income{% else %}Paycheck{% endif %}</td><td>{{p.owner}}</td><td>{{fmt_date(p.pay_date)}}</td><td>${{fmt_money(p.amount)}}</td><td><button class="btn-sm" type="button" onclick="openPaycheckEdit('{{p.id}}','{{p.owner|replace("'","\\'")}}','{{p.pay_date}}','{{fmt_money(p.amount)}}','{{p.income_type or "paycheck"}}')">Edit</button></td></tr>{% endfor %}
    </table>
    <div class="actions" style="margin-top:12px"><button type="button" onclick="closePaycheckManager()" class="btn-muted">Close</button></div>
  </div>
</div>

<!-- Paycheck Edit -->
<div id="paycheckEditModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Edit Income / Paycheck</h3>
    <form id="paycheckEditForm" class="stack-form" method="post" action="">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <div class="field-row"><label>Type</label><select id="pType" name="income_type" onchange="onPaycheckTypeChange()"><option value="paycheck">Paycheck</option><option value="other">Other Income</option></select></div>
      <div class="field-row"><label>Owner</label><input id="pOwner" type="text" name="owner" required></div>
      <div class="field-row"><label>Date</label><input id="pDate" type="date" name="pay_date" required></div>
      <div class="field-row"><label>Amount</label><input id="pAmount" type="number" step="0.01" name="amount" required></div>
      <div class="actions"><button type="submit" class="btn-gold">Save</button><button type="button" onclick="closePaycheckEdit()" class="btn-muted">Cancel</button></div>
    </form>
    <form id="deletePaycheckForm" method="post" action="" style="margin-top:10px" onsubmit="return confirmDelete('this paycheck')">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <button type="submit" class="btn-danger">Delete Paycheck</button>
    </form>
  </div>
</div>

<!-- Starting Balance -->
<div id="startOverrideModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Set Starting Balance</h3>
    <form id="startOverrideForm" method="post" action="/settings/starting-balance" class="stack-form" onsubmit="return submitStartOverride()">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <input id="soMonthHidden" type="hidden" name="starting_balance_month" value="{{month}}">
      <div class="field-row"><label>Month</label><input id="soMonth" type="text" inputmode="numeric" placeholder="MM-YYYY" required></div>
      <div class="field-row"><label>Starting Balance</label><input id="soAmount" type="number" step="0.01" name="starting_balance" required></div>
      <div class="actions"><button type="submit" class="btn-gold">Apply</button><button type="button" onclick="closeStartOverride()" class="btn-muted">Cancel</button></div>
    </form>
  </div>
</div>

<!-- Ledger Edit -->
<div id="ledgerEditModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Edit Checkbook Entry</h3>
    <form id="ledgerEditForm" class="stack-form" method="post" action="">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <div class="field-row"><label>Paid Date</label><input id="lDate" type="date" name="tx_date" required></div>
      <div class="field-row"><label>Label</label><input id="lLabel" type="text" name="label" required></div>
      <div class="field-row"><label>Amount</label><input id="lAmount" type="number" step="0.01" name="amount" required></div>
      <div class="field-row"><label>Note</label><input id="lNote" type="text" name="note"></div>
      <div class="actions"><button type="submit" class="btn-gold">Save</button><button type="button" onclick="closeLedgerEdit()" class="btn-muted">Cancel</button></div>
    </form>
    <form id="deleteLedgerForm" method="post" action="" style="margin-top:10px" onsubmit="return confirmDelete('this checkbook entry')">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <button type="submit" class="btn-danger">Delete Entry</button>
    </form>
  </div>
</div>

<!-- Trip Edit -->
<div id="tripEditModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Edit Trip</h3>
    <form id="tripEditForm" class="stack-form" method="post" action="">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <div class="field-row"><label>Name</label><input id="tripName" type="text" name="name" required></div>
      <div class="field-row"><label>Due Date</label><input id="tripDue" type="date" name="due_month" required></div>
      <div class="field-row"><label>Target</label><input id="tripTarget" type="number" step="0.01" name="target" required></div>
      <div class="field-row"><label>Saved</label><input id="tripSaved" type="number" step="0.01" name="saved" required></div>
      <div class="actions"><button type="submit" class="btn-gold">Save</button><button type="button" onclick="closeTripEdit()" class="btn-muted">Cancel</button></div>
    </form>
    <form id="deleteTripForm" method="post" action="" onsubmit="return confirmDelete('this trip goal')" style="margin-top:10px">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <button type="submit" class="btn-danger">Delete Trip</button>
    </form>
  </div>
</div>

<!-- Trip Contribution -->
<div id="tripContribModal" class="modal-overlay">
  <div class="modal-box">
    <h3 id="tripContribTitle">Add Trip Contribution</h3>
    <form id="tripContribForm" class="stack-form" method="post" action="">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <div class="field-row"><label>Paid Date</label><input type="date" name="paid_date" required></div>
      <div class="field-row"><label>Amount</label><input type="number" step="0.01" name="amount" required></div>
      <div class="actions"><button type="submit" class="btn-gold">Save Contribution</button><button type="button" onclick="closeTripContrib()" class="btn-muted">Cancel</button></div>
    </form>
  </div>
</div>

<!-- Promotion Edit -->
<div id="promotionEditModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Edit Promotion</h3>
    <form id="promotionEditForm" class="stack-form" method="post" action="">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <div class="field-row"><label>Card / Account</label><input id="promoCard" type="text" name="card_name" required></div>
      <div class="field-row"><label>Promotion</label><input id="promoName" type="text" name="promo_name" required></div>
      <div class="field-row"><label>Start Date</label><input id="promoStart" type="date" name="start_date"></div>
      <div class="field-row"><label>End Date</label><input id="promoEnd" type="date" name="end_date" required></div>
      <div class="field-row"><label>Promo Balance</label><input id="promoBalance" type="number" step="0.01" name="balance" required></div>
      <div class="field-row"><label>Note</label><input id="promoNote" type="text" name="note"></div>
      <div class="actions"><button type="submit" class="btn-gold">Save</button><button type="button" onclick="closePromotionEdit()" class="btn-muted">Cancel</button></div>
    </form>
    <form id="deletePromotionForm" method="post" action="" style="margin-top:10px" onsubmit="return confirmDelete('this promotion')">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <button type="submit" class="btn-danger">Delete Promotion</button>
    </form>
  </div>
</div>

<!-- Credit Edit -->
<div id="creditEditModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Edit Credit Card</h3>
    <form id="creditEditForm" class="stack-form" method="post" action="">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input type="hidden" name="anchor" value="credit-card-tracker">
      <div class="field-row"><label>Card Name</label><input id="creditCardName" type="text" name="card_name" required></div>
      <div class="field-row"><label>Interest Rate (%)</label><input id="creditInterestRate" type="number" step="0.01" name="interest_rate" required></div>
      <div class="field-row"><label>Credit Limit</label><input id="creditLimit" type="number" step="0.01" name="credit_limit" required></div>
      <div class="field-row"><label>Paid Off</label><div><input id="creditPaidOff" type="checkbox" name="paid_off"> No Balance</div></div>
      <div class="actions"><button type="submit" class="btn-gold">Save</button><button type="button" onclick="closeCreditEdit()" class="btn-muted">Cancel</button></div>
    </form>
  </div>
</div>

<!-- Loan Edit -->
<div id="loanEditModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Edit Loan</h3>
    <form id="loanEditForm" class="stack-form" method="post" action="">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input type="hidden" name="anchor" value="loans-tracker">
      <div class="field-row"><label>Loan Name</label><input id="loanName" type="text" name="loan_name" required></div>
      <div class="field-row"><label>Interest Rate (%)</label><input id="loanInterestRate" type="number" step="0.01" name="interest_rate" required></div>
      <div class="field-row"><label>Loan Amount</label><input id="loanAmount" type="number" step="0.01" name="loan_amount" required></div>
      <div class="field-row"><label>End Date</label><input id="loanEndDate" type="date" name="end_date"></div>
      <div class="field-row"><label>Note</label><input id="loanNote" type="text" name="note" maxlength="24"></div>
      <div class="actions"><button type="submit" class="btn-gold">Save</button><button type="button" onclick="closeLoanEdit()" class="btn-muted">Cancel</button></div>
    </form>
  </div>
</div>

<!-- Subscription Edit -->
<div id="subscriptionEditModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Edit Subscription</h3>
    <form id="subscriptionEditForm" class="stack-form" method="post" action="">
      <input type="hidden" name="_csrf" value="{{ csrf_token }}">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <div class="field-row"><label>Name</label><input id="subName" type="text" name="name" required></div>
      <div class="field-row"><label>Day Due</label><input id="subDayDue" type="number" min="1" max="31" name="day_due" required></div>
      <div class="field-row"><label>Payment</label><input id="subPayment" type="number" step="0.01" name="payment" required></div>
      <div class="field-row"><label>Recurring</label><div><input id="subRecurring" type="checkbox" name="recurring" onchange="toggleSubscriptionRecurringEdit()"> recurring</div></div>
      <div class="field-row sub-recurring-edit-fields"><label>Timeframe</label><select id="subRecurringTimeframe" name="recurring_timeframe" onchange="toggleSubscriptionTimeframeEdit()"><option value="monthly">Monthly</option><option value="yearly">Yearly</option><option value="specified_months">Specified # months</option></select></div>
      <div class="field-row" id="subYearlyMonthRow" style="display:none"><label>Yearly Month</label><select id="subYearlyMonth" name="yearly_month"><option value="1">January</option><option value="2">February</option><option value="3">March</option><option value="4">April</option><option value="5">May</option><option value="6">June</option><option value="7">July</option><option value="8">August</option><option value="9">September</option><option value="10">October</option><option value="11">November</option><option value="12">December</option></select></div>
      <div class="field-row" id="subRecurringMonthsRow" style="display:none"><label>Every # Months</label><input id="subRecurringEveryMonths" type="number" min="1" step="1" name="recurring_every_months"></div>
      <div class="actions"><button type="submit" class="btn-gold">Save</button><button type="button" onclick="closeSubscriptionEdit()" class="btn-muted">Cancel</button></div>
    </form>
    <form id="deleteSubscriptionForm" method="post" action="" style="margin-top:10px" onsubmit="return confirmDelete('this subscription')">
      <input type="hidden" name="_csrf" value="{{ csrf_token }}">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <button type="submit" class="btn-danger">Delete</button>
    </form>
  </div>
</div>

<!-- SETTINGS MODAL -->
<div id="settingsModal" class="modal-overlay">
  <div class="modal-box modal-wide" style="max-width:1200px;width:96vw;margin:3vh auto">
    <h3>Settings</h3>
    <div style="display:grid;grid-template-columns:180px 1fr;gap:16px;align-items:start">
      <div class="settings-sidebar" style="position:sticky;top:0">
        <button type="button" class="settings-tab-btn" onclick="showSettingsTab('paychecks')">Recurring Paychecks</button>
        <button type="button" class="settings-tab-btn" onclick="showSettingsTab('categories')">Categories</button>
        <button type="button" class="settings-tab-btn" onclick="showSettingsTab('recurringBills')">Recurring Bills</button>
        <button type="button" class="settings-tab-btn" onclick="showSettingsTab('backup')">Export</button>
        <button type="button" class="settings-tab-btn" onclick="showSettingsTab('theme')">Theme</button>
        <button type="button" class="settings-tab-btn" onclick="showSettingsTab('help')">Help / Instructions</button>
      </div>
      <div>
        <div id="settings-tab-paychecks" class="settings-tab">
          <h3>Recurring Paychecks</h3>
          <form method="post" action="/paycheck-rules/add">
            <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
            <input name="owner" placeholder="Owner" required>
            <input type="number" step="0.01" name="amount" placeholder="Amount" required>
            <select name="cadence" onchange="toggleRuleCadenceRow(this)"><option value="weekly">weekly</option><option value="biweekly" selected>biweekly</option><option value="monthly">monthly</option><option value="specified_day">specified day</option></select>
            <input type="number" min="1" max="31" name="day_of_month" placeholder="Day (1-31)" style="display:none;max-width:120px">
            <select name="timeframe" onchange="toggleRuleTimeframeRow(this)"><option value="monthly" selected>Monthly</option><option value="yearly">Yearly</option><option value="specified_months">Specified Months</option></select>
            <input type="text" name="months_mask" placeholder="e.g. 1,3,6,12" style="display:none;min-width:160px">
            <input type="date" name="next_date" required>
            <button class="btn-gold">Add Rule</button>
          </form>
          <form id="paycheck-rules-bulk-form" method="post" action="/paycheck-rules/bulk-update">
            <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input type="hidden" name="settings" value="1"><input type="hidden" name="settings_tab" value="paychecks">
            <table class="adaptive-table" style="margin-top:12px">
              <tr><th>Owner</th><th>Amount</th><th>Cadence</th><th>Day</th><th>Timeframe</th><th>Months</th><th>Next Date</th><th>Delete</th></tr>
              {% for r in paycheck_rules %}<tr>
                <input type="hidden" name="rule_id" value="{{r.id}}">
                <td><input name="owner" value="{{r.owner}}" required></td>
                <td><input type="number" step="0.01" name="amount" value="{{'%.2f'|format(r.amount or 0)}}" required></td>
                <td><select name="cadence" onchange="toggleRuleCadenceRow(this)"><option value="weekly" {% if r.cadence=='weekly' %}selected{% endif %}>weekly</option><option value="biweekly" {% if r.cadence=='biweekly' %}selected{% endif %}>biweekly</option><option value="monthly" {% if r.cadence=='monthly' %}selected{% endif %}>monthly</option><option value="specified_day" {% if r.cadence=='specified_day' %}selected{% endif %}>specified day</option></select></td>
                <td><input type="number" min="1" max="31" name="day_of_month" value="{{r.day_of_month or ''}}" style="max-width:80px;{% if r.cadence != 'specified_day' %}display:none;{% endif %}"></td>
                <td><select name="timeframe" onchange="toggleRuleTimeframeRow(this)"><option value="monthly" {% if (r.timeframe or 'monthly')=='monthly' %}selected{% endif %}>Monthly</option><option value="yearly" {% if (r.timeframe or '')=='yearly' %}selected{% endif %}>Yearly</option><option value="specified_months" {% if (r.timeframe or '')=='specified_months' %}selected{% endif %}>Specified Months</option></select></td>
                <td><input type="text" name="months_mask" value="{{r.months_mask or ''}}" placeholder="1,3,6,12" style="min-width:120px;{% if (r.timeframe or 'monthly') != 'specified_months' %}display:none;{% endif %}"></td>
                <td><input type="date" name="next_date" value="{{r.next_date}}" required></td>
                <td><button type="submit" name="delete_rule_id" value="{{r.id}}" formaction="/paycheck-rules/delete/{{r.id}}" formmethod="post" onclick="return confirmDelete('this recurring paycheck rule')" class="btn-danger btn-sm">Delete</button></td>
              </tr>{% endfor %}
            </table>
          </form>
          <form method="post" action="/paycheck-rules/generate" style="margin-top:10px"><input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="settings" value="1"><input type="hidden" name="settings_tab" value="paychecks"><input type="hidden" name="page" value="{{page}}"><button class="btn-gold">Generate This Month's Paychecks</button></form>
        </div>

        <div id="settings-tab-categories" class="settings-tab" style="display:none">
          <h3>Categories</h3>
          <form method="post" action="/categories/add"><input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input name="name" placeholder="new category"><button class="btn-gold">Add Category</button></form>
          <ul style="margin-top:10px">{% for c in categories %}<li>{{c.name}} {% if c.name not in ['bill','debt','trip'] %}<form style="display:inline" method="post" action="/categories/delete/{{c.id}}" onsubmit="return confirmDelete('this category')"><input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><button class="btn-danger btn-sm">Delete</button></form>{% endif %}</li>{% endfor %}</ul>
        </div>

        <div id="settings-tab-recurringBills" class="settings-tab" style="display:none">
          <h3>Recurring Bills</h3>
          <form method="post" action="/entries/add" style="border:1px solid var(--tint-mid);padding:12px;border-radius:var(--radius-sm);display:grid;grid-template-columns:1.5fr minmax(150px,1fr) minmax(150px,1fr) 0.9fr 1fr 1fr 0.9fr auto;gap:8px;align-items:center;margin-bottom:12px">
            <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input type="hidden" name="settings" value="1"><input type="hidden" name="settings_tab" value="recurringBills"><input type="hidden" name="entry_type" value="bill"><input type="hidden" name="recurring" value="on">
            <input type="text" name="name" placeholder="New recurring bill name" required>
            <div style="display:grid;gap:4px"><label style="font-size:11px;color:#6a5a8a">Start Date</label><input type="date" name="due_date" required></div>
            <div style="display:grid;gap:4px"><label style="font-size:11px;color:#6a5a8a">End Date</label><input type="date" name="recurring_end_date"></div>
            <input type="number" step="0.01" name="bill_amount" placeholder="Amount" required>
            <select name="recurring_timeframe" onchange="toggleRecurringBillMonths(this)"><option value="monthly" selected>Monthly</option><option value="yearly">Yearly</option><option value="specified_months">Specified # months</option></select>
            <input type="number" min="1" step="1" name="recurring_every_months" placeholder="# months" style="display:none">
            <select name="category">{% for c in categories %}{% if c.name != 'trip' %}<option value="{{c.name}}" {% if c.name=='bill' %}selected{% endif %}>{{c.name}}</option>{% endif %}{% endfor %}</select>
            <label style="font-size:13px"><input type="checkbox" name="autopay"> autopay</label>
            <button type="submit" class="btn-gold">Add Recurring Bill</button>
          </form>
          <div style="display:grid;gap:8px">
            {% for b in recurring_bills %}
            <form method="post" action="/bills/update/{{b.id}}" style="border:1px solid var(--tint-mid);padding:10px;border-radius:var(--radius-sm);display:grid;grid-template-columns:1.5fr minmax(150px,1fr) minmax(150px,1fr) 0.9fr 1fr 1fr 0.8fr auto;gap:8px;align-items:center">
              <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input type="hidden" name="settings" value="1"><input type="hidden" name="settings_tab" value="recurringBills"><input type="hidden" name="recurring" value="on">
              <input type="text" name="name" value="{{b.name}}" required>
              <div style="display:grid;gap:4px"><label style="font-size:11px;color:#6a5a8a">Start Date</label><input type="date" name="due_date" value="{{b.due_date}}" required></div>
              <div style="display:grid;gap:4px"><label style="font-size:11px;color:#6a5a8a">End Date</label><input type="date" name="recurring_end_date" value="{{b.recurring_end_date or ''}}"></div>
              <input type="number" step="0.01" name="amount" value="{{fmt_money(b.amount)}}" required>
              <select name="recurring_timeframe" onchange="toggleRecurringBillMonths(this)"><option value="monthly" {% if (b.recurring_timeframe or 'monthly')=='monthly' %}selected{% endif %}>Monthly</option><option value="yearly" {% if (b.recurring_timeframe or '')=='yearly' %}selected{% endif %}>Yearly</option><option value="specified_months" {% if (b.recurring_timeframe or '')=='specified_months' %}selected{% endif %}>Specified # months</option></select>
              <input type="number" min="1" step="1" name="recurring_every_months" value="{{b.recurring_every_months or ''}}" placeholder="# months" style="{% if (b.recurring_timeframe or 'monthly')!='specified_months' %}display:none;{% endif %}">
              <label style="font-size:13px"><input type="checkbox" name="autopay" {% if b.autopay %}checked{% endif %}> autopay</label>
              <button type="button" class="btn-danger btn-sm" onclick="document.getElementById('rb-del-{{b.id}}').submit()">🗑</button>
            </form>
            <form id="rb-del-{{b.id}}" method="post" action="/bills/unset-recurring/{{b.id}}" style="display:none"><input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}"><input type="hidden" name="settings" value="1"><input type="hidden" name="settings_tab" value="recurringBills"></form>
            {% endfor %}
          </div>
        </div>

        <div id="settings-tab-backup" class="settings-tab" style="display:none">
          <h3>Export</h3>
          <p style="font-size:13px;color:#6a5a8a;margin-bottom:12px">Export your household data to an organized Excel workbook.</p>
          <a class="pill active" href="/export/excel" style="display:inline-flex;text-decoration:none">⬇ Download Excel Export (.xlsx)</a>
        </div>

        <div id="settings-tab-theme" class="settings-tab" style="display:none">
          <h3>Accent Color</h3>
          <form id="settings-theme" method="post" action="/settings/update" class="stack-form">
            <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
            <div class="field-row"><label>Theme</label>
              <select name="accent_theme">
                <option value="slate" {% if theme_name=='slate' %}selected{% endif %}>Slate (Default)</option>
                <option value="pink" {% if theme_name=='pink' %}selected{% endif %}>Pink</option>
                <option value="blue" {% if theme_name=='blue' %}selected{% endif %}>Blue</option>
                <option value="purple" {% if theme_name=='purple' %}selected{% endif %}>Purple</option>
                <option value="red" {% if theme_name=='red' %}selected{% endif %}>Red</option>
              </select>
            </div>
          </form>
        </div>

        <div id="settings-tab-help" class="settings-tab" style="display:none">
          <h3>Full Instructions</h3>
          <ol style="line-height:1.7;font-size:13.5px;padding-left:18px">
            <li><b>Dashboard:</b> Quick month overview — balance, income, bills, and alerts.</li>
            <li><b>Bills:</b> Add bills, set due/planned pay dates, and mark paid. Use planner to avoid negative balance.</li>
            <li><b>Trips/Savings:</b> Track trip goals and contributions over time.</li>
            <li><b>Promotions:</b> Track promo deadlines and totals to avoid missed windows.</li>
            <li><b>Calendar:</b> Click events to edit records directly.</li>
            <li><b>History:</b> Manual entries, completed promotions, and paid-off loans.</li>
            <li><b>Export:</b> Download an organized Excel workbook for your records.</li>
            <li><b>Theme:</b> Choose your preferred visual style.</li>
          </ol>
          <div class="actions" style="margin-top:14px"><button type="button" class="btn-gold" onclick="openTour()">Replay Tutorial</button></div>
        </div>
      </div>
    </div>
    <div class="actions" style="margin-top:14px">
      <button type="button" class="btn-gold" onclick="saveSettingsActiveTab()">Save Settings</button>
      <button type="button" onclick="closeSettings()" class="btn-muted">Close</button>
    </div>
  </div>
</div>

<!-- TOUR MODAL -->
<div id="tourModal" class="modal-overlay">
  <div class="modal-box" style="max-width:600px">
    <h3>Welcome to NorthStar Ledger ★</h3>
    <div id="tourStepBody" style="line-height:1.55;font-size:14px"></div>
    <p id="tourStepCounter" style="font-size:12px;color:#8a7aaa;margin-top:10px"></p>
    <div class="actions" style="justify-content:space-between">
      <button type="button" onclick="skipTour()" class="btn-muted">Skip Tutorial</button>
      <div style="display:flex;gap:8px">
        <button type="button" id="tourBackBtn" onclick="tourPrev()" class="btn-muted">Back</button>
        <button type="button" id="tourNextBtn" onclick="tourNext()" class="btn-gold">Next</button>
      </div>
    </div>
  </div>
</div>

<!-- ROLLOVER MODAL -->
<div id="rolloverModal" class="modal-overlay">
  <div class="modal-box">
    <h3>Monthly Rollover</h3>
    <form method="post" action="/rollover" class="stack-form">
      <input type="hidden" name="month" value="{{month}}"><input type="hidden" name="view" value="{{view}}"><input type="hidden" name="page" value="{{page}}">
      <div class="field-row"><label>Source</label><input name="source_month" placeholder="YYYY-MM"></div>
      <div class="field-row"><label>Target</label><input name="target_month" placeholder="YYYY-MM"></div>
      <div class="actions"><button class="btn-gold">Rollover Recurring Bills</button><button type="button" onclick="closeRollover()" class="btn-muted">Close</button></div>
    </form>
  </div>
</div>

<!-- Day Events Modal -->
<div id="dayEventsModal" class="modal-overlay" style="z-index:10001">
  <div class="modal-box" style="max-height:80vh;overflow:auto">
    <h3 id="dayEventsTitle">Day Entries</h3>
    <div id="dayEventsBody"></div>
    <div class="actions" style="margin-top:12px"><button type="button" onclick="closeDayEvents()" class="btn-muted">Close</button></div>
  </div>
</div>

<!-- ═══════ JAVASCRIPT (unchanged from original) ═══════ -->
<script>
function addCsrfToForms(){
  const token = "{{ csrf_token }}";
  if(!token) return;
  document.querySelectorAll('form').forEach(f=>{
    if(f.querySelector('input[name="_csrf"]')) return;
    const i=document.createElement('input');
    i.type='hidden'; i.name='_csrf'; i.value=token;
    f.appendChild(i);
  });
}

function applyInputHints(){
  const supported = new Set(['text','date','number','email','search','month']);
  const humanize = (value='') => value.replace(/[_-]+/g,' ').replace(/\b\w/g, c => c.toUpperCase()).trim();
  document.querySelectorAll('input, textarea').forEach(el => {
    const tag = (el.tagName || '').toLowerCase();
    const type = (el.type || '').toLowerCase();
    if(tag === 'input' && !supported.has(type)) return;
    if(el.type === 'hidden') return;
    if(el.hasAttribute('placeholder') && el.getAttribute('placeholder')?.trim()) return;
    let hint = '';
    const row = el.closest('.field-row');
    const rowLabel = row?.querySelector('label');
    if(rowLabel) hint = rowLabel.textContent || '';
    if(!hint && el.name) hint = humanize(el.name);
    if(type === 'date') hint = 'MM-DD-YYYY';
    if(type === 'month') hint = 'MM-YYYY';
    if(hint) el.setAttribute('placeholder', hint);
  });
}

function normalizeNumberForInput(v){
  if(v === null || v === undefined) return '';
  return String(v).replace(/[$,\s]/g,'').trim();
}

function updateStickyOffsets(){
  const topCard = document.getElementById('top');
  if(!topCard) return;
  const root = document.documentElement;
  const h = Math.ceil(topCard.getBoundingClientRect().height || 0);
  root.style.setProperty('--sticky-notes-top', `${10 + h + 10}px`);
}

const RC_STORAGE_KEY = 'northstar_calc_display';
function rcDisplayEl(){ return document.getElementById('rcDisplay'); }
function saveCalculatorState(){ const el=rcDisplayEl(); if(!el) return; try{ localStorage.setItem(RC_STORAGE_KEY, el.value||'0'); }catch(e){} }
function loadCalculatorState(){ const el=rcDisplayEl(); if(!el) return; try{ const v=localStorage.getItem(RC_STORAGE_KEY); if(v!==null&&v!=='') el.value=v; }catch(e){} }
function clearCalculatorState(){ try{ localStorage.removeItem(RC_STORAGE_KEY); }catch(e){} }
function rcAppend(v){ const el=rcDisplayEl(); if(!el) return; const cur=el.value||'0'; el.value=(cur==='0'&&/[0-9.]/.test(v))?String(v):(cur+String(v)); saveCalculatorState(); }
function rcClear(){ const el=rcDisplayEl(); if(el){ el.value='0'; saveCalculatorState(); } }
function rcBack(){ const el=rcDisplayEl(); if(!el) return; const next=(el.value||'').slice(0,-1); el.value=next||'0'; saveCalculatorState(); }
function rcEval(){
  const el=rcDisplayEl(); if(!el) return;
  const expr=(el.value||'').replace(/÷/g,'/').replace(/×/g,'*').replace(/−/g,'-');
  if(!/^[0-9+\-*/%.()\s]+$/.test(expr)){ el.value='Error'; saveCalculatorState(); return; }
  try{ const val=Function('"use strict"; return ('+expr+')')(); el.value=Number.isFinite(val)?Number(val).toFixed(2):'Error'; }catch{ el.value='Error'; }
  saveCalculatorState();
}

function openEdit(id,due,plannedPay,amount,recurring,recurringTimeframe,recurringEveryMonths,recurringEndDate,autopay,name,paycheckBucket,paid,paidDate){
  document.getElementById('editForm').action='/bills/update/'+id;
  document.getElementById('deleteBillForm').action='/bills/delete/'+id;
  document.getElementById('editName').value=name||'';
  document.getElementById('editPaycheck').value=paycheckBucket||'';
  document.getElementById('editDue').value=due;
  document.getElementById('editPlannedPay').value=plannedPay||due;
  document.getElementById('editAmount').value=normalizeNumberForInput(amount);
  document.getElementById('editRecurring').checked=!!recurring;
  document.getElementById('editRecurringTimeframe').value=recurringTimeframe||'monthly';
  document.getElementById('editRecurringEveryMonths').value=normalizeNumberForInput(recurringEveryMonths)||'';
  document.getElementById('editRecurringEndDate').value=recurringEndDate||'';
  toggleBillRecurringOptions();
  document.getElementById('editAutopay').checked=!!autopay;
  document.getElementById('editPaid').checked=!!paid;
  document.getElementById('editPaidDate').value=paidDate||'';
  document.getElementById('editModal').style.display='block';
}
function closeEdit(){ document.getElementById('editModal').style.display='none'; }

function openPostponeModal(id,plannedDate){
  document.getElementById('postponeForm').action='/bills/postpone/'+id;
  document.getElementById('postponeDate').value=plannedDate||'';
  document.getElementById('postponeNote').value='';
  document.getElementById('removePostponeFlag').value='0';
  document.getElementById('postponeModal').style.display='block';
}
function closePostponeModal(){ document.getElementById('postponeModal').style.display='none'; }
function submitRemovePostpone(){
  const form=document.getElementById('postponeForm');
  document.getElementById('removePostponeFlag').value='1';
  try{ sessionStorage.setItem('ns_scroll_y',String(window.scrollY||0)); }catch(e){}
  if(form&&typeof form.requestSubmit==='function') form.requestSubmit(); else if(form) form.submit();
}

function toggleBillRecurringOptions(){
  const recurring=document.getElementById('editRecurring');
  const opts=document.getElementById('editRecurringOptions');
  const timeframe=document.getElementById('editRecurringTimeframe');
  const monthsRow=document.getElementById('editRecurringMonthsRow');
  const endDateRow=document.getElementById('editRecurringEndDateRow');
  if(!recurring||!opts||!timeframe||!monthsRow||!endDateRow) return;
  const on=!!recurring.checked;
  opts.style.display=on?'block':'none';
  const showMonths=(on&&timeframe.value==='specified_months');
  monthsRow.style.display=showMonths?'block':'none';
  endDateRow.style.display=on?'block':'none';
  const monthsInput=document.getElementById('editRecurringEveryMonths');
  if(monthsInput) monthsInput.required=showMonths;
  const endInput=document.getElementById('editRecurringEndDate');
  if(endInput&&!on) endInput.value='';
}

function openPaycheckManager(){ document.getElementById('paycheckManagerModal').style.display='block'; }
function closePaycheckManager(){ document.getElementById('paycheckManagerModal').style.display='none'; }
function openPaycheckEdit(id,owner,date,amount,incomeType){
  closePaycheckManager();
  document.getElementById('paycheckEditForm').action='/paychecks/update/'+id;
  document.getElementById('deletePaycheckForm').action='/paychecks/delete/'+id;
  document.getElementById('pOwner').value=owner||'';
  document.getElementById('pDate').value=date||'';
  document.getElementById('pAmount').value=normalizeNumberForInput(amount)||'';
  document.getElementById('pType').value=incomeType||'paycheck';
  onPaycheckTypeChange();
  document.getElementById('paycheckEditModal').style.display='block';
}
function onPaycheckTypeChange(){
  const t=document.getElementById('pType'); const o=document.getElementById('pOwner'); if(!t||!o) return;
  if(t.value==='other'){ o.value='Income'; o.readOnly=true; o.required=false; }
  else{ o.readOnly=false; if(o.value==='Income') o.value=''; o.required=true; }
}
function closePaycheckEdit(){ document.getElementById('paycheckEditModal').style.display='none'; }

function openStartOverride(month,amount){
  const raw=month||''; const display=/^\d{4}-\d{2}$/.test(raw)?`${raw.slice(5,7)}-${raw.slice(0,4)}`:raw;
  document.getElementById('soMonth').value=display; document.getElementById('soMonthHidden').value=raw;
  document.getElementById('soAmount').value=amount||''; document.getElementById('startOverrideModal').style.display='block';
}
function submitStartOverride(){
  const vis=(document.getElementById('soMonth')?.value||'').trim(); const hidden=document.getElementById('soMonthHidden');
  const m=vis.match(/^(\d{2})-(\d{4})$/);
  if(!m){ alert('Please use MM-YYYY format for Month.'); return false; }
  if(hidden) hidden.value=`${m[2]}-${m[1]}`; return true;
}
function closeStartOverride(){ document.getElementById('startOverrideModal').style.display='none'; }

function openLedgerEdit(id,txDate,label,amount,note){
  document.getElementById('ledgerEditForm').action='/ledger/update/'+id;
  document.getElementById('deleteLedgerForm').action='/ledger/delete/'+id;
  document.getElementById('lDate').value=txDate; document.getElementById('lLabel').value=label||'';
  document.getElementById('lAmount').value=normalizeNumberForInput(amount); document.getElementById('lNote').value=note||'';
  document.getElementById('ledgerEditModal').style.display='block';
}
function closeLedgerEdit(){ document.getElementById('ledgerEditModal').style.display='none'; }
function confirmDelete(thing){ return window.confirm(`Are you sure you want to delete ${thing}? This cannot be undone.`); }

function openTripEdit(id,name,due,target,saved){
  document.getElementById('tripEditForm').action='/trips/update/'+id;
  document.getElementById('deleteTripForm').action='/trips/delete/'+id;
  document.getElementById('tripName').value=name||''; document.getElementById('tripDue').value=due||'';
  document.getElementById('tripTarget').value=normalizeNumberForInput(target)||'';
  document.getElementById('tripSaved').value=normalizeNumberForInput(saved)||'';
  document.getElementById('tripEditModal').style.display='block';
}
function closeTripEdit(){ document.getElementById('tripEditModal').style.display='none'; }
function openTripContrib(id,name){ document.getElementById('tripContribForm').action='/trips/contribute/'+id; document.getElementById('tripContribTitle').innerText='Add Trip Contribution — '+name; document.getElementById('tripContribModal').style.display='block'; }
function closeTripContrib(){ document.getElementById('tripContribModal').style.display='none'; }

function openPromotionEdit(id,card,promo,startDate,endDate,balance,note){
  document.getElementById('promotionEditForm').action='/promotions/update/'+id;
  document.getElementById('deletePromotionForm').action='/promotions/delete/'+id;
  document.getElementById('promoCard').value=card||''; document.getElementById('promoName').value=promo||'';
  document.getElementById('promoStart').value=startDate||''; document.getElementById('promoEnd').value=endDate||'';
  document.getElementById('promoBalance').value=normalizeNumberForInput(balance)||''; document.getElementById('promoNote').value=note||'';
  document.getElementById('promotionEditModal').style.display='block';
}
function closePromotionEdit(){ document.getElementById('promotionEditModal').style.display='none'; }

function openSubscriptionEdit(id,name,dayDue,payment,recurring,timeframe,everyMonths,yearlyMonth){
  document.getElementById('subscriptionEditForm').action='/subscriptions/update/'+id;
  document.getElementById('deleteSubscriptionForm').action='/subscriptions/delete/'+id;
  document.getElementById('subName').value=name||''; document.getElementById('subDayDue').value=normalizeNumberForInput(dayDue)||'';
  document.getElementById('subPayment').value=normalizeNumberForInput(payment)||''; document.getElementById('subRecurring').checked=!!recurring;
  document.getElementById('subRecurringTimeframe').value=timeframe||'monthly';
  document.getElementById('subRecurringEveryMonths').value=normalizeNumberForInput(everyMonths)||'';
  document.getElementById('subYearlyMonth').value=normalizeNumberForInput(yearlyMonth)||'1';
  toggleSubscriptionRecurringEdit(); toggleSubscriptionTimeframeEdit();
  document.getElementById('subscriptionEditModal').style.display='block';
}
function closeSubscriptionEdit(){ document.getElementById('subscriptionEditModal').style.display='none'; }

function toggleSubscriptionRecurring(checkboxEl){
  const form=checkboxEl?.closest('form'); if(!form) return;
  const on=!!checkboxEl.checked;
  form.querySelectorAll('.sub-recurring-fields').forEach(el=>el.style.display=on?'':'none');
  const tf=form.querySelector('select[name="recurring_timeframe"]');
  if(tf&&on){ toggleSubscriptionTimeframe(tf); } else { const mr=form.querySelector('.sub-recurring-months'); const yr=form.querySelector('.sub-yearly-month'); if(mr) mr.style.display='none'; if(yr) yr.style.display='none'; }
}
function toggleSubscriptionTimeframe(selectEl){
  const form=selectEl?.closest('form'); if(!form) return;
  const mr=form.querySelector('.sub-recurring-months'); const yr=form.querySelector('.sub-yearly-month');
  if(mr) mr.style.display=(selectEl.value==='specified_months')?'':'none';
  if(yr) yr.style.display=(selectEl.value==='yearly')?'':'none';
}
function toggleSubscriptionRecurringEdit(){
  const r=document.getElementById('subRecurring'); const on=r&&r.checked;
  document.querySelectorAll('.sub-recurring-edit-fields').forEach(el=>el.style.display=on?'':'none');
  if(on){ toggleSubscriptionTimeframeEdit(); } else { const row=document.getElementById('subRecurringMonthsRow'); const yr=document.getElementById('subYearlyMonthRow'); if(row) row.style.display='none'; if(yr) yr.style.display='none'; }
}
function toggleSubscriptionTimeframeEdit(){
  const t=document.getElementById('subRecurringTimeframe'); const row=document.getElementById('subRecurringMonthsRow'); const yr=document.getElementById('subYearlyMonthRow'); if(!t) return;
  if(row) row.style.display=(t.value==='specified_months')?'':'none';
  if(yr) yr.style.display=(t.value==='yearly')?'':'none';
}

function openCreditEdit(id,cardName,interestRate,creditLimit,paidOff){
  document.getElementById('creditEditForm').action='/credit/update/'+id;
  document.getElementById('creditCardName').value=cardName||''; document.getElementById('creditInterestRate').value=normalizeNumberForInput(interestRate)||'';
  document.getElementById('creditLimit').value=normalizeNumberForInput(creditLimit)||''; document.getElementById('creditPaidOff').checked=!!paidOff;
  document.getElementById('creditEditModal').style.display='block';
}
function closeCreditEdit(){ document.getElementById('creditEditModal').style.display='none'; }

function openLoanEdit(id,loanName,interestRate,loanAmount,note,endDate){
  document.getElementById('loanEditForm').action='/loans/update/'+id;
  document.getElementById('loanName').value=loanName||''; document.getElementById('loanInterestRate').value=normalizeNumberForInput(interestRate)||'';
  document.getElementById('loanAmount').value=normalizeNumberForInput(loanAmount)||''; document.getElementById('loanNote').value=note||''; document.getElementById('loanEndDate').value=endDate||'';
  document.getElementById('loanEditModal').style.display='block';
}
function closeLoanEdit(){ document.getElementById('loanEditModal').style.display='none'; }

const TOUR_STEPS=[
  {title:'Dashboard',text:'Use Dashboard for quick monthly overview — balance, income, bills, and alerts.'},
  {title:'Bills + Planner',text:'Add bills and due dates, then check paycheck planner to prevent negative balance. Set up recurring bills so you don\'t have to enter them each month.'},
  {title:'New Month Rollover',text:'When starting a new month, select "Add Recurring Bills/Income" in the top navigation to automatically add bills.'},
  {title:'Trips/Savings',text:'Track trip goals and contributions over time.'},
  {title:'Promotions',text:'Track promo totals and deadlines so promotions do not expire unexpectedly.'},
  {title:'Calendar',text:'View monthly bills, paychecks, trips, and promotions together on one calendar.'},
  {title:'History + Export',text:'Use History to view transactions and paid-off items. Export data to Excel from Settings.'},
  {title:'Settings/Theme',text:'Pick your preferred theme and adjust recurring setup from the Settings tabs.'}
];
let tourIndex=0;
function renderTourStep(){
  const step=TOUR_STEPS[tourIndex];
  const body=document.getElementById('tourStepBody'); const counter=document.getElementById('tourStepCounter');
  const back=document.getElementById('tourBackBtn'); const next=document.getElementById('tourNextBtn');
  if(!body||!counter||!back||!next) return;
  body.innerHTML=`<h4 style="margin:0 0 8px 0;font-family:'Cinzel',serif;color:var(--purple-deep)">${step.title}</h4><p style="margin:0">${step.text}</p>`;
  counter.textContent=`Step ${tourIndex+1} of ${TOUR_STEPS.length}`;
  back.disabled=tourIndex===0; back.style.opacity=tourIndex===0?.5:1;
  next.textContent=(tourIndex===TOUR_STEPS.length-1)?'Finish':'Next';
}

function openSettings(){ document.getElementById('settingsModal').style.display='block'; }
function closeSettings(){ document.getElementById('settingsModal').style.display='none'; }
function toggleRuleCadenceRow(selectEl){ if(!selectEl) return; const row=selectEl.closest('tr')||selectEl.parentElement; const dayInput=row?row.querySelector('input[name="day_of_month"]'):null; if(!dayInput) return; const is=(selectEl.value==='specified_day'); dayInput.style.display=is?'':'none'; dayInput.required=is; }
function toggleRuleTimeframeRow(selectEl){ if(!selectEl) return; const row=selectEl.closest('tr')||selectEl.parentElement; const mi=row?row.querySelector('input[name="months_mask"]'):null; if(!mi) return; const is=(selectEl.value==='specified_months'); mi.style.display=is?'':'none'; mi.required=is; }
function toggleRecurringBillMonths(selectEl){ if(!selectEl) return; const c=selectEl.closest('form')||selectEl.parentElement; const mi=c?c.querySelector('input[name="recurring_every_months"]'):null; const yr=c?c.querySelector('.sub-yearly-month'):null; const ys=c?c.querySelector('select[name="yearly_month"]'):null; const is=(selectEl.value==='specified_months'); const iy=(selectEl.value==='yearly'); if(mi){ mi.style.display=is?'':'none'; mi.required=is; } if(yr) yr.style.display=iy?'':'none'; if(ys) ys.required=iy; }
function saveSettingsActiveTab(){
  const paychecksTab=document.getElementById('settings-tab-paychecks'); const themeTab=document.getElementById('settings-tab-theme');
  if(paychecksTab&&paychecksTab.style.display!=='none'){ const f=document.getElementById('paycheck-rules-bulk-form'); if(f) return f.submit(); }
  if(themeTab&&themeTab.style.display!=='none'){ const tf=document.getElementById('settings-theme'); if(tf) return tf.submit(); }
  const fallback=document.getElementById('settings-theme')||document.getElementById('paycheck-rules-bulk-form'); if(fallback) fallback.submit();
}
function openTour(){ tourIndex=0; document.getElementById('tourModal').style.display='block'; renderTourStep(); }
function closeTour(){ document.getElementById('tourModal').style.display='none'; }
function skipTour(){ closeTour(); }
function tourPrev(){ if(tourIndex>0){ tourIndex--; renderTourStep(); } }
function tourNext(){ if(tourIndex<TOUR_STEPS.length-1){ tourIndex++; renderTourStep(); } else{ closeTour(); } }
function openRollover(){ document.getElementById('rolloverModal').style.display='block'; }
function closeRollover(){ document.getElementById('rolloverModal').style.display='none'; }
function openDayEvents(dayKey){
  const body=document.getElementById('dayEventsBody'); const src=document.getElementById('day-events-'+dayKey); const title=document.getElementById('dayEventsTitle');
  if(!body||!src||!title) return;
  const parts=(dayKey||'').split('-'); if(parts.length===3){ title.textContent=`Entries for ${parts[1]}-${parts[2]}-${parts[0]}`; } else{ title.textContent='Day Entries'; }
  body.innerHTML=src.innerHTML; document.getElementById('dayEventsModal').style.display='block';
}
function closeDayEvents(){ document.getElementById('dayEventsModal').style.display='none'; }
function showSettingsTab(tab){
  const tabs=['paychecks','categories','recurringBills','backup','theme','help'];
  tabs.forEach(t=>{ const el=document.getElementById('settings-tab-'+t); if(el) el.style.display=(t===tab)?'block':'none'; });
}
function onAddCategoryChange(){ const c=document.getElementById('addCategory'); const t=document.getElementById('tripSelect'); if(!c||!t) return; t.style.display=(c.value==='trip')?'inline-block':'none'; }
function onIncomeKindChange(){
  const kind=document.getElementById('incomeKind'); const owner=document.getElementById('incomeOwner'); const type=document.getElementById('entryType');
  if(!kind||!owner) return;
  const incomeMode=type&&type.value==='income';
  if(!incomeMode){ owner.required=false; owner.readOnly=false; return; }
  if(kind.value==='other'){ owner.readOnly=false; owner.placeholder='Income source (e.g. Bonus)'; if(owner.value==='Income') owner.value=''; owner.required=true; }
  else{ owner.readOnly=false; owner.placeholder='Owner'; if(owner.value==='Other Income') owner.value=''; owner.required=true; }
}
function applyCalendarFilters(){
  const show={ bill:!!document.getElementById('tgBill')?.checked, promotion:!!document.getElementById('tgPromotion')?.checked, trip:!!document.getElementById('tgTrip')?.checked, paycheck:!!document.getElementById('tgPaycheck')?.checked, subscription:!!document.getElementById('tgSubscription')?.checked };
  document.querySelectorAll('.cal-event').forEach(el=>{ const t=el.getAttribute('data-type'); el.style.display=show[t]?'block':'none'; });
}
function wireDateHints(){
  const isInModal=(input)=>!!input.closest('#editModal, #paycheckEditModal, #startOverrideModal, #ledgerEditModal, #tripEditModal, #tripContribModal, #promotionEditModal, #settings-tab-paychecks, #settings-tab-recurringBills');
  const enhance=(input,hintText)=>{
    if(isInModal(input)) return;
    let wrap=input.closest('.date-hint-wrap');
    if(!wrap){ wrap=document.createElement('span'); wrap.className='date-hint-wrap'; input.parentNode.insertBefore(wrap,input); wrap.appendChild(input); const hint=document.createElement('span'); hint.className='date-hint'; hint.textContent=hintText; wrap.appendChild(hint); }
    else{ const hint=wrap.querySelector('.date-hint'); if(hint&&!hint.textContent) hint.textContent=hintText; }
    const sync=()=>wrap.classList.toggle('has-value',!!input.value);
    input.addEventListener('change',sync); input.addEventListener('input',sync); sync();
  };
  document.querySelectorAll('input[type="date"]').forEach(input=>enhance(input,''));
  document.querySelectorAll('input[type="month"]').forEach(input=>enhance(input,'Month'));
}
function calcCreditCard(){
  const b=parseFloat(document.getElementById('ccBalance')?.value||'0'); const apr=parseFloat(document.getElementById('ccApr')?.value||'0');
  const n=parseInt(document.getElementById('ccMonths')?.value||'0',10); const monthlyPay=parseFloat(document.getElementById('ccMonthlyPay')?.value||'0');
  const out=document.getElementById('ccResult'); if(!out) return;
  if(!(b>0)||apr<0){ out.innerHTML='Please enter a valid balance and APR.'; return; }
  const r=(apr/100)/12;
  if(monthlyPay>0){
    if(r>0&&monthlyPay<=b*r){ out.innerHTML='Monthly payment is too low to reduce this balance.'; return; }
    let bal=b,months=0,totalPaid=0;
    while(bal>0&&months<1200){ const interest=bal*r; let pp=monthlyPay-interest; if(pp<=0) break; if(pp>bal) pp=bal; bal-=pp; totalPaid+=interest+pp; months++; }
    if(bal>0){ out.innerHTML='Could not compute payoff timeline.'; return; }
    out.innerHTML=`Estimated Payoff: <b>${months} months</b><br>Total Paid: <b>$${totalPaid.toFixed(2)}</b><br>Total Interest: <b>$${(totalPaid-b).toFixed(2)}</b>`; return;
  }
  if(!(n>0)){ out.innerHTML='Enter payoff timeline (months) or monthly payment.'; return; }
  const pay=r===0?b/n:b*(r*Math.pow(1+r,n))/(Math.pow(1+r,n)-1);
  out.innerHTML=`Needed Monthly Payment: <b>$${pay.toFixed(2)}</b><br>Total Paid by ${n} months: <b>$${(pay*n).toFixed(2)}</b><br>Total Interest: <b>$${(pay*n-b).toFixed(2)}</b>`;
}
function resetCreditCalc(){ ['ccBalance','ccApr','ccMonths','ccMonthlyPay'].forEach(id=>{ const el=document.getElementById(id); if(el) el.value=''; }); const out=document.getElementById('ccResult'); if(out) out.innerHTML='Enter values and click Calculate Debt.'; }
function toggleEntryRecurringEnd(cb){ const container=cb?cb.closest('#billFields'):null; if(!container) return; const endWrap=container.querySelector('.entry-recurring-end'); const endInput=container.querySelector('input[name="recurring_end_date"]'); const on=!!cb.checked; if(endWrap) endWrap.style.display=on?'inline-block':'none'; if(endInput&&!on) endInput.value=''; }
function onEntryTypeChange(){
  const type=document.getElementById('entryType'); const income=document.getElementById('incomeFields'); const bill=document.getElementById('billFields'); const tripContribution=document.getElementById('tripContributionFields');
  if(!type||!income||!bill||!tripContribution) return;
  const im=type.value==='income'; const bm=type.value==='bill'; const tm=type.value==='trip_contribution';
  income.style.display=im?'contents':'none'; bill.style.display=bm?'contents':'none'; tripContribution.style.display=tm?'contents':'none';
  const owner=document.querySelector('input[name="owner"]'); const payDate=document.querySelector('input[name="pay_date"]'); const incomeAmount=document.querySelector('input[name="income_amount"]');
  const name=document.querySelector('input[name="name"]'); const dueDate=document.querySelector('input[name="due_date"]'); const billAmount=document.querySelector('input[name="bill_amount"]');
  const ct=document.querySelector('select[name="contrib_trip_id"]'); const cd=document.querySelector('input[name="contrib_date"]'); const ca=document.querySelector('input[name="contrib_amount"]');
  if(owner) owner.required=im; if(payDate) payDate.required=im; if(incomeAmount) incomeAmount.required=im;
  if(name) name.required=bm; if(dueDate) dueDate.required=bm; if(billAmount) billAmount.required=bm;
  if(ct) ct.required=tm; if(cd) cd.required=tm; if(ca) ca.required=tm;
  document.querySelectorAll('#billFields').forEach(bf=>{ const cb=bf.querySelector('input[name="recurring"]'); if(cb) toggleEntryRecurringEnd(cb); });
  onAddCategoryChange(); onIncomeKindChange();
}

window.addEventListener('DOMContentLoaded', ()=>{
  addCsrfToForms(); applyInputHints(); onAddCategoryChange(); onEntryTypeChange(); onIncomeKindChange(); applyCalendarFilters(); wireDateHints(); loadCalculatorState(); updateStickyOffsets();
  window.addEventListener('resize', updateStickyOffsets);
  document.querySelectorAll('select[name="cadence"]').forEach(toggleRuleCadenceRow);
  document.querySelectorAll('select[name="timeframe"]').forEach(toggleRuleTimeframeRow);
  document.querySelectorAll('select[name="recurring_timeframe"]').forEach(sel=>{ toggleRecurringBillMonths(sel); toggleSubscriptionTimeframe(sel); });
  document.querySelectorAll('input[name="recurring"]').forEach(cb=>{ if(cb.closest('#subscriptions')) toggleSubscriptionRecurring(cb); });
  try{
    const forms=document.querySelectorAll('form');
    forms.forEach(f=>{ f.addEventListener('submit',()=>{ sessionStorage.setItem('ns_scroll_y',String(window.scrollY||0)); }); });
    const savedY=sessionStorage.getItem('ns_scroll_y');
    if(savedY!==null){ const y=parseInt(savedY,10); if(!Number.isNaN(y)) window.scrollTo(0,y); sessionStorage.removeItem('ns_scroll_y'); }
  }catch(e){}
  {% if show_tour %}openTour();{% endif %}
  const params=new URLSearchParams(window.location.search);
  if(params.get('settings')==='1'){ openSettings(); showSettingsTab(params.get('settings_tab')||'paychecks'); }
  else{ showSettingsTab('paychecks'); }
});
</script>
</body>
</html>